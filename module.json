{
  "id": "mtt-merchants",
  "title": "Merchants, Trades and Transactions",
  "description": "A Foundry VTT module for managing merchants, trade sessions, shops, services, and transactions.",
  "version": "0.1.0",
  "compatibility": {
    "minimum": "14",
    "verified": "14"
  },
  "authors": [
    {
      "name": "Alchimiste36"
    }
  ],
  "url": "https://github.com/Alchimiste36/Foundry-Merchants-and-trade",
  "manifest": "https://raw.githubusercontent.com/Alchimiste36/Foundry-Merchants-and-trade/main/module.json",
  "download": "https://github.com/Alchimiste36/Foundry-Merchants-and-trade/archive/refs/heads/main.zip",
  "esmodules": ["mtt.mjs"],
  "styles": ["css/mtt.css"],
  "socket": true,
  "languages": [
    {
      "lang": "fr",
      "name": "Français",
      "path": "lang/fr.json"
    },
    {
      "lang": "en",
      "name": "English",
      "path": "lang/en.json"
    }
  ],
  "documentTypes": {
    "Actor": {
      "merchant": {
        "label": "mtt.actorTypes.merchant",
        "htmlFields": ["merchant.description"]
      }
    }
  }
}
