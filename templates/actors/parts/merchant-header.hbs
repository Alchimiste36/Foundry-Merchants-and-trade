<header class="mtt-merchant-header">
  <div class="mtt-merchant-header-left">
    <button
      class="mtt-merchant-image-button"
      type="button"
      {{#if mtt.canEditMerchant}}
        data-action="editMerchantImage"
        data-tooltip="{{localize 'mtt.merchant.image.edit'}}"
      {{else}}
        disabled
        data-tooltip="{{actor.name}}"
      {{/if}}
    >
      <img
        class="mtt-merchant-image {{#if mtt.canEditMerchant}}mtt-merchant-image-editable{{/if}}"
        src="{{actor.img}}"
        alt="{{actor.name}}"
      />
    </button>

    <div class="mtt-merchant-header-title-area">
      {{#if mtt.canEditMerchant}}
        <input
          class="mtt-merchant-name-input"
          name="name"
          type="text"
          value="{{actor.name}}"
          data-mtt-merchant-field="name"
          placeholder="{{localize 'mtt.merchant.name.placeholder'}}"
          spellcheck="false"
        />
      {{else}}
        <h1 class="mtt-merchant-name">{{actor.name}}</h1>
      {{/if}}
      

      <div class="mtt-merchant-state-row">
        {{#if mtt.isEditable}}
          <button
            class="mtt-merchant-lock-button"
            type="button"
            data-action="toggleLock"
            {{#unless mtt.isEditable}}disabled{{/unless}}
            data-tooltip="{{#if mtt.isLocked}}{{localize 'mtt.sheet.unlock'}}{{else}}{{localize 'mtt.sheet.lock'}}{{/if}}"
          >
            {{#if mtt.isLocked}}
              <i class="fas fa-lock"></i>
            {{else}}
              <i class="fas fa-lock-open"></i>
            {{/if}}
          </button>
        {{/if}}

        <button
          class="mtt-merchant-open-button"
          type="button"
          data-action="toggleOpen"
          {{#unless mtt.canEditMerchant}}disabled{{/unless}}
          data-tooltip="{{#if system.status.isOpen}}{{localize 'mtt.sheet.closeMerchant'}}{{else}}{{localize 'mtt.sheet.openMerchant'}}{{/if}}"
        >
          {{#if system.status.isOpen}}
            <i class="fas fa-door-open"></i>
          {{else}}
            <i class="fas fa-door-closed"></i>
          {{/if}}
        </button>
      </div>

      <div class="mtt-merchant-nav-row">
        <nav class="mtt-merchant-tab-nav" aria-label="{{localize 'mtt.navigation.label'}}">
          <button
            class="mtt-merchant-tab-nav-btn {{#if (eq mtt.activeTab 'products')}}mtt-merchant-tab-nav-btn-active{{/if}}"
            type="button"
            data-action="selectTab"
            data-tab="products"
            data-tooltip="{{localize 'mtt.tabs.products'}}"
          >
            <i class="fas fa-box"></i>
          </button>

          <button
            class="mtt-merchant-tab-nav-btn {{#if (eq mtt.activeTab 'services')}}mtt-merchant-tab-nav-btn-active{{/if}}"
            type="button"
            data-action="selectTab"
            data-tab="services"
            data-tooltip="{{localize 'mtt.tabs.services'}}"
          >
            <i class="fas fa-handshake"></i>
          </button>

          <button
            class="mtt-merchant-tab-nav-btn {{#if (eq mtt.activeTab 'journal')}}mtt-merchant-tab-nav-btn-active{{/if}}"
            type="button"
            data-action="selectTab"
            data-tab="journal"
            data-tooltip="{{localize 'mtt.tabs.journal'}}"
          >
            <i class="fas fa-book"></i>
          </button>

          {{#if mtt.isEditable}}
            <button
              class="mtt-merchant-tab-nav-btn {{#if (eq mtt.activeTab 'configuration')}}mtt-merchant-tab-nav-btn-active{{/if}}"
              type="button"
              data-action="selectTab"
              data-tab="configuration"
              data-tooltip="{{localize 'mtt.tabs.configuration'}}"
            >
              <i class="fas fa-gear"></i>
            </button>
          {{/if}}
        </nav>
      </div>

      <div class="mtt-nav-info">
        <div class="mtt-merchant-title-block">
          {{#if (eq mtt.activeTab "products")}}
            <h2 class="mtt-merchant-section-title">{{localize "mtt.tabs.products"}}</h2>
          {{/if}}
          {{#if (eq mtt.activeTab "services")}}
            <h2 class="mtt-merchant-section-title">{{localize "mtt.tabs.services"}}</h2>
          {{/if}}
          {{#if (eq mtt.activeTab "configuration")}}
            <h2 class="mtt-merchant-section-title">{{localize "mtt.tabs.configuration"}}</h2>
          {{/if}}
          {{#if (eq mtt.activeTab "journal")}}
            <h2 class="mtt-merchant-section-title">{{localize "mtt.tabs.journal"}}</h2>
          {{/if}}
        </div>
      </div>
    </div>
  </div>

  <div class="mtt-merchant-header-right">
    <div class="mtt-merchant-header-manager">
      {{#if mtt.canEditMerchant}}
        <div class="mtt-merchant-manager-fields">
          
          <label class="mtt-merchant-field">
            <input
              class="mtt-merchant-field-input"
              type="text"
              name="system.manager.displayName"
              value="{{system.manager.displayName}}"
              data-mtt-merchant-field="manager.displayName"
              placeholder="{{localize 'mtt.manager.displayName.placeholder'}}"
            />
          </label>
        </div>
      {{else}}
        <div class="mtt-merchant-manager-summary">
          <span class="mtt-merchant-manager-name">{{system.manager.displayName}}</span>
          <button
          class="mtt-merchant-header-action"
          type="button"
          data-action="rollNegotiation"
          data-tooltip="{{localize 'mtt.configuration.rollNegotiation'}}"
        >
          <i class="fas fa-dice-d20"></i>
        </button>
        </div>
      {{/if}}
    </div>


    {{#if mtt.isEditable}}
      <div class="mtt-merchant-header-wallet-summary">
        {{#if mtt.hasHeaderCurrencies}}
          {{#each mtt.headerCurrencies as |currency|}}
            <span class="mtt-merchant-header-wallet-currency">
              <strong>{{currency.label}}</strong>
              {{currency.amount}}
            </span>
          {{/each}}
        {{else}}
          <span class="mtt-merchant-header-wallet-empty">
            {{localize "mtt.configuration.walletSummaryEmpty"}}
          </span>
        {{/if}}
      </div>
    {{/if}}
  </div>
</header>
