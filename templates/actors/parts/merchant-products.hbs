<section class="mtt-merchant-products">
  <header class="mtt-merchant-products-header">
    <div class="mtt-merchant-products-title-block">
      <h2 class="mtt-merchant-section-title">{{localize "mtt.products.title"}}</h2>
      <p class="mtt-merchant-section-subtitle">{{localize "mtt.products.subtitle"}}</p>
    </div>

    {{#if mtt.canEditMerchant}}
      <button
        class="mtt-merchant-product-create-button"
        type="button"
        data-action="createItem"
        data-tooltip="{{localize 'mtt.actions.createItem'}}"
      >
        <i class="fas fa-plus"></i>
        <span>{{localize "mtt.actions.createItem"}}</span>
      </button>
    {{/if}}
  </header>

  <div class="mtt-merchant-products-drop-zone">
    {{#if mtt.canEditMerchant}}
      <p class="mtt-merchant-products-drop-help">
        {{localize "mtt.products.dropHelp"}}
      </p>
    {{/if}}

    {{#if items.length}}
      <ol class="mtt-merchant-product-list">
        {{#each items as |item|}}
          <li class="mtt-merchant-product-row draggable" data-item-id="{{item.id}}">
            <div class="mtt-merchant-product-main">
              <img
                class="mtt-merchant-product-image"
                src="{{item.img}}"
                alt="{{item.name}}"
                data-tooltip="{{item.name}}"
              />

              <div class="mtt-merchant-product-identity">
                {{#if @root.mtt.canEditMerchant}}
                  <input
                    class="mtt-merchant-product-name-input"
                    type="text"
                    value="{{item.displayName}}"
                    data-mtt-product-field="displayName"
                  />
                {{else}}
                  <span class="mtt-merchant-product-name">{{item.displayName}}</span>
                {{/if}}
                {{#if (ne item.displayName item.name)}}
                  <span class="mtt-merchant-product-source-name">
                    {{localize "mtt.products.sourceName"}}
                    {{item.name}}
                  </span>
                {{/if}}
                <span class="mtt-merchant-product-type">{{item.type}}</span>
                {{#if item.isHidden}}
                  <span class="mtt-merchant-product-tag mtt-merchant-product-tag-hidden">
                    {{localize "mtt.products.tags.hidden"}}
                  </span>
                {{/if}}

                {{#if item.requiresApproval}}
                  <span class="mtt-merchant-product-tag mtt-merchant-product-tag-approval">
                    {{localize "mtt.products.tags.requiresApproval"}}
                  </span>
                {{/if}}
              </div>
            </div>

            <div class="mtt-merchant-product-details">
              {{#if @root.mtt.canEditMerchant}}
                <input
                  class="mtt-merchant-product-quantity-input"
                  type="number"
                  min="0"
                  value="{{item.quantity}}"
                  data-mtt-product-field="quantity"
                />
              {{else}}
                {{#if item.hasQuantity}}
                  <span class="mtt-merchant-product-quantity">
                    {{localize "mtt.products.quantity.short"}}
                    {{item.quantity}}
                  </span>
                {{else}}
                  <span class="mtt-merchant-product-quantity mtt-merchant-product-quantity-empty">
                    {{localize "mtt.products.quantity.undefined"}}
                  </span>
                {{/if}}
              {{/if}}
            </div>

            <div class="mtt-merchant-product-actions">
              <button
                class="mtt-merchant-product-action"
                type="button"
                data-action="editItem"
                data-tooltip="{{localize 'mtt.actions.edit'}}"
              >
                <i class="fas fa-edit"></i>
              </button>

              {{#if @root.mtt.canEditMerchant}}
                <button
                  class="mtt-merchant-product-action mtt-merchant-product-delete"
                  type="button"
                  data-action="deleteItem"
                  data-tooltip="{{localize 'mtt.actions.delete'}}"
                >
                  <i class="fas fa-trash"></i>
                </button>
              {{/if}}
            </div>
            {{#if @root.mtt.canEditMerchant}}
              <div class="mtt-merchant-product-secret">
                <h4 class="mtt-merchant-product-secret-title">
                  {{localize "mtt.products.secret.title"}}
                </h4>

                <label class="mtt-merchant-product-secret-field">
                  <span>{{localize "mtt.products.secret.name"}}</span>
                  <input
                    class="mtt-merchant-product-secret-input"
                    type="text"
                    value="{{item.secretName}}"
                    data-mtt-product-field="secretName"
                  />
                </label>

                <label class="mtt-merchant-product-secret-field">
                  <span>{{localize "mtt.products.secret.price"}}</span>
                  <input
                    class="mtt-merchant-product-secret-input"
                    type="text"
                    value="{{item.secretPrice}}"
                    data-mtt-product-field="secretPrice"
                  />
                </label>

                <label class="mtt-merchant-product-secret-field">
                  <span>{{localize "mtt.products.secret.description"}}</span>
                  <textarea
                    class="mtt-merchant-product-secret-textarea"
                    data-mtt-product-field="secretDescription"
                  >{{item.secretDescription}}</textarea>
                </label>
              </div>
            {{else if item.hasSecretInfos}}
              <div class="mtt-merchant-product-secret mtt-merchant-product-secret-readonly">
                <h4 class="mtt-merchant-product-secret-title">
                  {{localize "mtt.products.secret.title"}}
                </h4>

                {{#if item.secretName}}
                  <p><strong>{{localize "mtt.products.secret.name"}}</strong> {{item.secretName}}</p>
                {{/if}}

                {{#if item.secretPrice}}
                  <p><strong>{{localize "mtt.products.secret.price"}}</strong> {{item.secretPrice}}</p>
                {{/if}}

                {{#if item.secretDescription}}
                  <p><strong>{{localize "mtt.products.secret.description"}}</strong> {{item.secretDescription}}</p>
                {{/if}}
              </div>
            {{/if}}
          </li>
        {{/each}}
      </ol>
    {{else}}
      <div class="mtt-merchant-products-empty">
        <i class="fas fa-box-open"></i>
        <h3 class="mtt-merchant-products-empty-title">{{localize "mtt.products.empty.title"}}</h3>
        <p class="mtt-merchant-products-empty-text">{{localize "mtt.products.empty.text"}}</p>

        {{#if mtt.canEditMerchant}}
          <p class="mtt-merchant-products-empty-help">{{localize "mtt.products.empty.help"}}</p>
        {{/if}}
      </div>
    {{/if}}
  </div>
</section>