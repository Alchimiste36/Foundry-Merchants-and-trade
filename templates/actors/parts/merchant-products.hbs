<section class="mtt-merchant-products">
  <header class="mtt-merchant-products-header">
    <div class="mtt-merchant-products-title-block">
      <h2 class="mtt-merchant-section-title">{{localize "mtt.products.title"}}</h2>
      <p class="mtt-merchant-section-subtitle">{{localize "mtt.products.subtitle"}}</p>
    </div>

    {{#if mtt.canEditMerchant}}
      <div class="mtt-merchant-products-actions-row">
        <button
          class="mtt-merchant-product-create-button"
          type="button"
          data-action="createItem"
          data-tooltip="{{localize 'mtt.actions.createItem'}}"
        >
          <i class="fas fa-plus"></i>
        </button>
        <button
          class="mtt-merchant-product-create-button"
          type="button"
          data-action="createProductCategory"
          data-tooltip="{{localize 'mtt.products.category.add'}}"
        >
          <i class="fas fa-plus"></i>
        </button>
      </div>
    {{/if}}
  </header>

  <div class="mtt-merchant-products-drop-zone">
    {{#if mtt.canEditMerchant}}
      <p class="mtt-merchant-products-drop-help">
        {{localize "mtt.products.dropHelp"}}
      </p>
    {{/if}}

    {{#if productCategories.length}}
      <div class="mtt-merchant-product-categories">
        {{#each productCategories as |category|}}
          <section
            class="mtt-merchant-product-category-group {{#if category.isCollapsed}}mtt-merchant-product-category-collapsed{{/if}}"
            data-mtt-category-drop
            data-category="{{category.categoryValue}}"
            data-tooltip="{{localize 'mtt.products.category.dropTooltip'}}"
          >
            <header class="mtt-merchant-product-category-header">
              <div class="mtt-merchant-product-category-header-main">
                <button
                  class="mtt-merchant-product-category-toggle"
                  type="button"
                  data-action="toggleProductCategory"
                  data-category="{{category.categoryValue}}"
                  data-tooltip="{{#if category.isCollapsed}}{{localize 'mtt.products.category.toggleShow'}}{{else}}{{localize 'mtt.products.category.toggleHide'}}{{/if}}"
                >
                  {{#if category.isCollapsed}}
                    <i class="fas fa-chevron-right"></i>
                  {{else}}
                    <i class="fas fa-chevron-down"></i>
                  {{/if}}
                </button>

                <div class="mtt-merchant-product-category-title-block">
                  {{#if @root.mtt.canEditMerchant}}
                    {{#if category.isSystemCategory}}
                      <h3 class="mtt-merchant-product-category-title">
                        {{category.name}}
                        <span class="mtt-merchant-product-category-count">({{category.count}})</span>
                      </h3>
                    {{else}}
                      <input
                        class="mtt-merchant-product-category-input"
                        type="text"
                        value="{{category.name}}"
                        data-mtt-category-name
                        data-category-id="{{category.categoryValue}}"
                        data-tooltip="{{localize 'mtt.products.category.rename'}}"
                      />
                    {{/if}}
                  {{else}}
                    <h3 class="mtt-merchant-product-category-title">
                      {{category.name}}
                      <span class="mtt-merchant-product-category-count">({{category.count}})</span>
                    </h3>
                  {{/if}}
                </div>
              </div>

              {{#if @root.mtt.canEditMerchant}}
                {{#unless category.isSystemCategory}}
                  <button
                    class="mtt-merchant-product-action mtt-merchant-product-category-delete"
                    type="button"
                    data-action="deleteProductCategory"
                    data-category-id="{{category.categoryValue}}"
                    data-tooltip="{{localize 'mtt.products.category.delete'}}"
                  >
                    <i class="fas fa-trash"></i>
                  </button>
                {{/unless}}
              {{/if}}
            </header>

            {{#unless category.isCollapsed}}
              <ol class="mtt-merchant-product-category-item-list">
                {{#each category.items as |item|}}
                  <li
                    class="mtt-merchant-product-row draggable"
                    data-item-id="{{item.id}}"
                    data-mtt-product-id="{{item.id}}"
                    {{#if @root.mtt.canEditMerchant}}draggable="true"{{/if}}
                  >
                    <div class="mtt-merchant-product-main">
                      <img
                        class="mtt-merchant-product-image"
                        src="{{item.img}}"
                        alt="{{item.name}}"
                        data-tooltip="{{item.name}}"
                      />

                      <div class="mtt-merchant-product-identity">
                        {{#if @root.mtt.canEditMerchant}}
                          <input
                            class="mtt-merchant-product-name-input"
                            type="text"
                            value="{{item.displayName}}"
                            data-mtt-product-field="displayName"
                          />
                        {{else}}
                          <span class="mtt-merchant-product-name">{{item.displayName}}</span>
                        {{/if}}
                        {{#if (ne item.displayName item.name)}}
                          <span class="mtt-merchant-product-source-name">
                            {{localize "mtt.products.sourceName"}}
                            {{item.name}}
                          </span>
                        {{/if}}
                        <span class="mtt-merchant-product-type">{{item.type}}</span>
                        {{#if item.isHidden}}
                          <span class="mtt-merchant-product-tag mtt-merchant-product-tag-hidden">
                            {{localize "mtt.products.tags.hidden"}}
                          </span>
                        {{/if}}

                        {{#if item.requiresApproval}}
                          <span class="mtt-merchant-product-tag mtt-merchant-product-tag-approval">
                            {{localize "mtt.products.tags.requiresApproval"}}
                          </span>
                        {{/if}}
                      </div>
                    </div>

                    <div class="mtt-merchant-product-details">
                      {{#if @root.mtt.canEditMerchant}}
                        <input
                          class="mtt-merchant-product-quantity-input"
                          type="number"
                          min="0"
                          value="{{item.quantity}}"
                          data-mtt-product-field="quantity"
                        />

                        <div class="mtt-merchant-product-price">
                          {{#if item.hasFreePrice}}
                            <span class="mtt-merchant-product-free-price-indicator" data-tooltip="{{localize 'mtt.price.freePriceTooltip'}}">
                              <i class="fas fa-scale-balanced"></i>
                              {{localize "mtt.price.freePrice"}}
                            </span>
                            <label class="mtt-merchant-product-price-field">
                              <span class="mtt-merchant-product-price-label" data-tooltip="{{localize 'mtt.price.minimumPriceHint'}}">{{localize "mtt.price.minimumPrice"}}</span>
                              <input
                                class="mtt-merchant-product-price-value"
                                type="number"
                                min="0"
                                step="0.01"
                                value="{{item.minimumPriceValue}}"
                                data-mtt-product-field="minimumPriceValue"
                              />
                            </label>
                          {{else}}
                            <label class="mtt-merchant-product-price-field">
                              <span class="mtt-merchant-product-price-label">{{localize "mtt.products.price.base"}}</span>
                              <input
                                class="mtt-merchant-product-price-value"
                                type="number"
                                min="0"
                                step="0.01"
                                value="{{item.priceValue}}"
                                placeholder="{{localize 'mtt.products.price.valuePlaceholder'}}"
                                data-mtt-product-field="priceValue"
                              />
                              <input
                                class="mtt-merchant-product-price-currency"
                                type="text"
                                value="{{item.priceCurrency}}"
                                placeholder="{{localize 'mtt.products.price.currencyPlaceholder'}}"
                                data-mtt-product-field="priceCurrency"
                              />
                            </label>
                            <span
                              class="mtt-merchant-product-adjusted-price"
                              data-tooltip="{{localize 'mtt.configuration.sellPercentApplied'}}"
                            >
                              {{localize "mtt.products.price.adjusted"}}
                              {{#if item.hasPrice}}
                                {{item.displayPriceLabel}}
                              {{else}}
                                {{localize "mtt.products.price.undefined"}}
                              {{/if}}
                            </span>
                          {{/if}}
                        </div>
                      {{else}}
                        {{#if item.hasQuantity}}
                          <span class="mtt-merchant-product-quantity">
                            {{localize "mtt.products.quantity.short"}}
                            {{item.quantity}}
                          </span>
                        {{else}}
                          <span class="mtt-merchant-product-quantity mtt-merchant-product-quantity-empty">
                            {{localize "mtt.products.quantity.undefined"}}
                          </span>
                        {{/if}}

                        <div class="mtt-merchant-product-price-readonly">
                          {{#if item.hasFreePrice}}
                            <span class="mtt-merchant-product-free-price" data-tooltip="{{localize 'mtt.price.freePriceIconTooltip'}}">
                              <i class="fas fa-scale-balanced"></i>
                            </span>
                          {{else if item.hasPrice}}
                            <span class="mtt-merchant-product-price-display">{{item.displayPriceLabel}}</span>
                          {{else}}
                            <span class="mtt-merchant-product-price-undefined">{{localize "mtt.products.price.undefined"}}</span>
                          {{/if}}
                        </div>
                      {{/if}}
                    </div>

                    <div class="mtt-merchant-product-actions">
                      {{#unless item.isHidden}}
                        <button
                          class="mtt-merchant-product-action"
                          type="button"
                          data-action="addProductToSession"
                          data-tooltip="{{localize 'mtt.sessions.actions.addProduct'}}"
                        >
                          <i class="fas fa-cart-plus"></i>
                        </button>
                      {{/unless}}

                      <button
                        class="mtt-merchant-product-action"
                        type="button"
                        data-action="editItem"
                        data-tooltip="{{localize 'mtt.actions.edit'}}"
                      >
                        <i class="fas fa-edit"></i>
                      </button>

                      {{#if @root.mtt.canEditMerchant}}
                        <button
                          class="mtt-merchant-product-action {{#if item.hasFreePrice}}mtt-merchant-product-action-active{{/if}}"
                          type="button"
                          data-action="toggleProductFreePrice"
                          data-tooltip="{{#if item.hasFreePrice}}{{localize 'mtt.price.freePriceTooltip'}}{{else}}{{localize 'mtt.price.freePrice'}}{{/if}}"
                        >
                          <i class="fas fa-scale-balanced"></i>
                        </button>

                        <button
                          class="mtt-merchant-product-action mtt-merchant-product-delete"
                          type="button"
                          data-action="deleteItem"
                          data-tooltip="{{localize 'mtt.actions.delete'}}"
                        >
                          <i class="fas fa-trash"></i>
                        </button>
                      {{/if}}
                    </div>
                    <div class="mtt-merchant-product-secret">
                      <button
                        class="mtt-merchant-product-secret-toggle"
                        type="button"
                        data-action="toggleProductSecret"
                        data-tooltip="{{#if item.isSecretExpanded}}{{localize 'mtt.products.secret.toggleHide'}}{{else}}{{localize 'mtt.products.secret.toggleShow'}}{{/if}}"
                      >
                        {{#if item.isSecretExpanded}}
                          <i class="fas fa-eye-slash"></i>
                        {{else}}
                          <i class="fas fa-eye"></i>
                        {{/if}}
                      </button>

                      {{#if item.hasSecretInfos}}
                        <span class="mtt-merchant-product-secret-indicator">
                          {{localize "mtt.products.secret.hasSecret"}}
                        </span>
                      {{/if}}

                      {{#if item.isSecretExpanded}}
                        {{#if @root.mtt.canEditMerchant}}
                          <div class="mtt-merchant-product-secret-fields">
                            <label class="mtt-merchant-product-secret-field">
                              <span>{{localize "mtt.products.secret.name"}}</span>
                              <input
                                class="mtt-merchant-product-secret-input"
                                type="text"
                                value="{{item.secretName}}"
                                data-mtt-product-field="secretName"
                              />
                            </label>

                            <label class="mtt-merchant-product-secret-field">
                              <span>{{localize "mtt.products.secret.price"}}</span>
                              <input
                                class="mtt-merchant-product-secret-input"
                                type="text"
                                value="{{item.secretPrice}}"
                                data-mtt-product-field="secretPrice"
                              />
                            </label>

                            <label class="mtt-merchant-product-secret-field">
                              <span>{{localize "mtt.products.secret.description"}}</span>
                              <textarea
                                class="mtt-merchant-product-secret-textarea"
                                data-mtt-product-field="secretDescription"
                              >{{item.secretDescription}}</textarea>
                            </label>
                          </div>
                        {{else if item.hasSecretInfos}}
                          <div class="mtt-merchant-product-secret-readonly">
                            {{#if item.secretName}}
                              <p><strong>{{localize "mtt.products.secret.name"}}</strong> {{item.secretName}}</p>
                            {{/if}}

                            {{#if item.secretPrice}}
                              <p><strong>{{localize "mtt.products.secret.price"}}</strong> {{item.secretPrice}}</p>
                            {{/if}}

                            {{#if item.secretDescription}}
                              <p><strong>{{localize "mtt.products.secret.description"}}</strong> {{item.secretDescription}}</p>
                            {{/if}}
                          </div>
                        {{else}}
                          <p class="mtt-merchant-product-secret-empty">
                            {{localize "mtt.products.secret.empty"}}
                          </p>
                        {{/if}}
                      {{/if}}
                    </div>
                  </li>
                {{/each}}
              </ol>
            {{/unless}}
          </section>
        {{/each}}
      </div>
    {{else}}
      <div class="mtt-merchant-products-empty">
        <i class="fas fa-box-open"></i>
        <h3 class="mtt-merchant-products-empty-title">{{localize "mtt.products.empty.title"}}</h3>
        <p class="mtt-merchant-products-empty-text">{{localize "mtt.products.empty.text"}}</p>

        {{#if mtt.canEditMerchant}}
          <p class="mtt-merchant-products-empty-help">{{localize "mtt.products.empty.help"}}</p>
        {{/if}}
      </div>
    {{/if}}
  </div>
</section>
