<section class="mtt-merchant-products">
  <div class="mtt-merchant-products-drop-zone">

    {{#if productCategories.length}}
      <div class="mtt-merchant-product-categories">
        {{#each productCategories as |category|}}
          <section
            class="mtt-merchant-product-category-group {{#if category.isCollapsed}}mtt-merchant-product-category-collapsed{{/if}}"
            data-mtt-category-drop
            data-category="{{category.categoryValue}}"
            <!--data-tooltip="{{localize 'mtt.products.category.dropTooltip'}}"-->
          >
            <header class="mtt-merchant-product-category-header {{#unless category.isVisible}}mtt-merchant-product-category-header-hidden{{/unless}}">
              <div class="mtt-merchant-product-category-header-main">
                <button
                  class="mtt-merchant-product-category-toggle"
                  type="button"
                  data-action="toggleProductCategory"
                  data-category="{{category.categoryValue}}"
                  data-tooltip="{{#if category.isCollapsed}}{{localize 'mtt.products.category.toggleShow'}}{{else}}{{localize 'mtt.products.category.toggleHide'}}{{/if}}"
                >
                  {{#if category.isCollapsed}}
                    <i class="fas fa-chevron-right"></i>
                  {{else}}
                    <i class="fas fa-chevron-down"></i>
                  {{/if}}
                </button>

                <div class="mtt-merchant-product-category-title-block">
                  {{#if @root.mtt.canEditMerchant}}
                    {{#if category.isSystemCategory}}
                      <h3 class="mtt-merchant-product-category-title">
                        {{category.name}}
                        <span class="mtt-merchant-product-category-count">({{category.count}})</span>
                      </h3>
                    {{else}}
                      <input
                        class="mtt-merchant-product-category-input"
                        type="text"
                        value="{{category.name}}"
                        data-mtt-category-name
                        data-category-id="{{category.categoryValue}}"
                        data-tooltip="{{localize 'mtt.products.category.rename'}}"
                      />
                    {{/if}}
                  {{else}}
                    <h3 class="mtt-merchant-product-category-title">
                      {{category.name}}
                      <span class="mtt-merchant-product-category-count">({{category.count}})</span>
                    </h3>
                  {{/if}}
                </div>
              </div>

              {{#if @root.mtt.isEditable}}
                <button
                  class="mtt-merchant-product-action mtt-merchant-product-category-visibility"
                  type="button"
                  data-action="toggleProductCategoryVisibility"
                  data-category-id="{{category.categoryValue}}"
                  data-system-category="{{category.isSystemCategory}}"
                  data-tooltip="{{#if category.isVisible}}{{localize 'mtt.products.category.hide'}}{{else}}{{localize 'mtt.products.category.show'}}{{/if}}"
                >
                  {{#if category.isVisible}}
                    <i class="fas fa-eye"></i>
                  {{else}}
                    <i class="fas fa-eye-slash"></i>
                  {{/if}}
                </button>
              {{/if}}

              {{#if @root.mtt.canEditMerchant}}
                {{#unless category.isSystemCategory}}
                  <button
                    class="mtt-merchant-product-action mtt-merchant-product-category-delete"
                    type="button"
                    data-action="deleteProductCategory"
                    data-category-id="{{category.categoryValue}}"
                    data-tooltip="{{localize 'mtt.products.category.delete'}}"
                  >
                    <i class="fas fa-trash"></i>
                  </button>
                {{/unless}}
              {{/if}}
            </header>

            {{#unless category.isCollapsed}}
              <ol class="mtt-merchant-product-category-item-list {{#unless category.isVisible}}mtt-merchant-product-category-item-list-hidden{{/unless}}">
                {{#each category.items as |item|}}
                  <li
                    class="mtt-merchant-product-row draggable {{#unless item.isVisible}}mtt-merchant-catalog-item-hidden{{/unless}}"
                    data-item-id="{{item.id}}"
                    data-mtt-product-id="{{item.id}}"
                    {{#if @root.mtt.isEditable}}
                      data-mtt-catalog-context-menu
                      data-catalog-kind="product"
                    {{/if}}
                    {{#if @root.mtt.canEditMerchant}}draggable="true"{{/if}}
                  >

                  <div class="mtt-merchant-product-quantity">
                    {{#if @root.mtt.isLimited}}
                    {{else}}
                      {{#if @root.mtt.canEditMerchant}}
                        <input
                          class="mtt-merchant-product-quantity-input"
                          type="number"
                          min="0"
                          value="{{item.quantity}}"
                          placeholder="{{localize 'mtt.products.quantity.unlimited'}}"
                          data-mtt-product-field="quantity"
                        />
                      {{else}}
                        {{#if item.hasQuantity}}
                          <div class="mtt-merchant-product-quantity">
                            {{item.quantity}}x
                          </div>
                        {{else}}
                          <span class="mtt-merchant-product-quantity mtt-merchant-product-quantity-empty">
                            <i class="fa-solid fa-infinity"></i>
                          </span>
                        {{/if}}
                      {{/if}}
                    {{/if}}
                    </div>


                    <div class="mtt-merchant-product-main {{#if item.isLimitedOwnership}}mtt-merchant-product-ownership-limited{{/if}}{{#if item.isObserverOwnership}}mtt-merchant-product-ownership-observer{{/if}}">
                      <img
                        class="mtt-merchant-product-image"
                        data-action="editItem"
                        src="{{item.img}}"
                        alt="{{item.name}}"
                        data-tooltip="{{item.name}}"
                      />

                      <div class="mtt-merchant-product-identity">
                        {{#if @root.mtt.canEditMerchant}}
                          <div class="mtt-merchant-catalog-name-row">
                            {{#if item.hasSecrets}}
                              <i
                                class="fa-solid fa-mask mtt-merchant-secret-indicator"
                                data-tooltip="{{item.secretTooltip}}"
                                aria-hidden="true"
                              ></i>
                            {{/if}}
                            {{#if item.requiresApproval}}
                              <i
                                class="fas fa-user-check mtt-merchant-approval-indicator"
                                data-tooltip="{{localize 'mtt.products.tags.requiresApproval'}}"
                                aria-hidden="true"
                              ></i>
                            {{/if}}
                          <input
                            class="mtt-merchant-product-name-input"
                            type="text"
                            value="{{item.displayName}}"
                            data-mtt-product-field="displayName"
                          />
                          </div>
                        {{else}}
                          {{#if @root.mtt.isEditable}}
                            <span class="mtt-merchant-catalog-name-row">
                              {{#if item.hasSecrets}}
                                <i
                                  class="fa-solid fa-mask mtt-merchant-secret-indicator"
                                  data-tooltip="{{item.secretTooltip}}"
                                  aria-hidden="true"
                                ></i>
                              {{/if}}
                              {{#if item.requiresApproval}}
                                <i
                                  class="fas fa-user-check mtt-merchant-approval-indicator"
                                  data-tooltip="{{localize 'mtt.products.tags.requiresApproval'}}"
                                  aria-hidden="true"
                                ></i>
                              {{/if}}
                            <span
                              class="mtt-merchant-product-name"
                            >
                              {{item.displayName}}
                            </span>
                            </span>
                          {{else}}
                            <span class="mtt-merchant-catalog-name-row">
                              <span class="mtt-merchant-product-name">{{item.displayName}}</span>
                            </span>
                          {{/if}}
                        {{/if}}
                        {{#if @root.mtt.isEditable}}
                          {{#if (ne item.displayName item.name)}}
                            <span class="mtt-merchant-product-source-name">
                              {{localize "mtt.products.sourceName"}}
                              {{item.name}}
                            </span>
                          {{/if}}
                        {{/if}}
                      </div>
                    </div>



                    <div class="mtt-merchant-product-price-bloc">
                      {{#if @root.mtt.isLimited}}
                      {{else}}
                        {{#if @root.mtt.canEditMerchant}}
                          <div class="mtt-merchant-product-price">
                            {{#if item.hasFreePrice}}
                              <label class="mtt-merchant-product-price-field">
                                <input
                                  class="mtt-merchant-product-price-value"
                                  type="number"
                                  min="0"
                                  step="1"
                                  value="{{item.minimumPriceValue}}"
                                  data-mtt-product-field="minimumPriceValue"
                                />
                              </label>
                            {{else}}
                              <label class="mtt-merchant-product-price-field">
                                <input
                                  class="mtt-merchant-product-price-value"
                                  type="number"
                                  min="0"
                                  step="1"
                                  value="{{item.priceValue}}"
                                  placeholder="{{localize 'mtt.products.price.valuePlaceholder'}}"
                                  data-mtt-product-field="priceValue"
                                />
                              </label>
                            {{/if}}
                            <select
                              class="mtt-merchant-product-price-currency"
                              data-mtt-product-field="priceCurrency"
                            >
                              {{#each @root.mtt.currencyOptions as |opt|}}
                                <option value="{{opt.key}}" title="{{opt.label}}"{{#if (eq opt.key item.selectedCurrencyKey)}} selected{{/if}}>
                                  {{#if opt.isFreePrice}}{{opt.label}}{{else}}{{opt.abbreviation}}{{/if}}
                                </option>
                              {{/each}}
                            </select>
                          </div>
                        {{else}}
                          <div class="mtt-merchant-product-price-readonly">
                            {{#if item.hasFreePrice}}
                              <span class="mtt-merchant-product-free-price-label">{{localize "mtt.price.freePrice"}}</span>
                            {{else if item.hasPrice}}
                              <span class="mtt-merchant-product-price-display">{{item.displayPriceLabel}}</span>
                            {{else}}
                              <span class="mtt-merchant-product-price-undefined">{{localize "mtt.products.price.undefined"}}</span>
                            {{/if}}
                          </div>
                          {{/if}}
                      {{/if}}
                    </div>


                    <div class="mtt-merchant-product-actions">
                      {{#if @root.mtt.isLimited}}
                      {{else}}
                        {{#if item.isVisible}}
                        {{#unless @root.mtt.session.isSubmitted}}
                          <button
                            class="mtt-merchant-product-action"
                            type="button"
                            data-action="addProductToSession"
                            data-tooltip="{{localize 'mtt.sessions.actions.addProduct'}}"
                          >
                            <i class="fas fa-cart-plus"></i>
                          </button>
                        {{/unless}}
                        {{/if}}

                        {{#if @root.mtt.isEditable}}
                          <button
                            class="mtt-merchant-product-action"
                            type="button"
                            data-action="toggleCatalogItemVisibility"
                            data-catalog-kind="product"
                            data-tooltip="{{#if item.isVisible}}{{localize 'mtt.products.hide'}}{{else}}{{localize 'mtt.products.show'}}{{/if}}"
                          >
                            {{#if item.isVisible}}
                              <i class="fas fa-eye"></i>
                            {{else}}
                              <i class="fas fa-eye-slash"></i>
                            {{/if}}
                          </button>
                        {{/if}}

                        {{#if @root.mtt.canEditMerchant}}
                          <button
                            class="mtt-merchant-product-action mtt-merchant-product-delete"
                            type="button"
                            data-action="deleteItem"
                            data-tooltip="{{localize 'mtt.actions.delete'}}"
                          >
                            <i class="fas fa-trash"></i>
                          </button>
                        {{/if}}
                      {{/if}}
                    </div>
                  </li>
                {{/each}}
              </ol>
            {{/unless}}
          </section>
        {{/each}}
      </div>
    {{else}}
      <div class="mtt-merchant-products-empty">
        <i class="fas fa-box-open"></i>
        <h3 class="mtt-merchant-products-empty-title">{{localize "mtt.products.empty.title"}}</h3>
        <p class="mtt-merchant-products-empty-text">{{localize "mtt.products.empty.text"}}</p>

        {{#if mtt.canEditMerchant}}
          <p class="mtt-merchant-products-empty-help">{{localize "mtt.products.empty.help"}}</p>
        {{/if}}
      </div>
    {{/if}}
  </div>
  {{#if mtt.canEditMerchant}}
      <div class="mtt-merchant-products-actions-row">
        <button
          class="mtt-merchant-product-create-button"
          type="button"
          data-action="createProductCategory"
          data-tooltip="{{localize 'mtt.products.category.add'}}"
        >
          <i class="fas fa-plus"></i>
        </button>
        <h2 class="mtt-merchant-session-title">{{localize 'mtt.products.category.add'}}</h2>
      </div>
    {{/if}}
</section>
