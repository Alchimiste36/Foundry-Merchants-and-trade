<aside class="mtt-merchant-session-sidebar">
  {{!-- MTT shop — session de transaction commerciale --}}
  {{#if isShop}}
    <section class="mtt-merchant-session">
    <header class="mtt-merchant-session-header">
      <div class="mtt-merchant-session-title-block">
        {{#if mtt.session.client.actorImg}}
          <div>
            <img class="mtt-merchant-session-actor-image" src="{{mtt.session.client.actorImg}}" alt="{{mtt.session.client.actorName}}" />
          </div>
        {{/if}}
        <div>
        <h2 class="mtt-merchant-session-title">{{localize "mtt.sessions.title"}}</h2>
        <div class="mtt-merchant-session-actor-name">{{mtt.session.client.actorName}}</div>
        {{#if mtt.session.buyerFortune.length}}
          <div class="mtt-merchant-session-buyer-fortune">
            <span>{{localize "mtt.sessions.buyerFortune"}}</span>
            <span class="mtt-merchant-session-buyer-fortune-values">
              {{#each mtt.session.buyerFortune as |currency|}}
                <span>{{currency.value}} {{currency.abbreviation}}</span>
              {{/each}}
            </span>
          </div>
        {{/if}}
      </div>
      </div>
    </header>

    {{#if mtt.session.hasSession}}
      <section class="mtt-merchant-session-section mtt-merchant-session-side-buyer">
      <header class="mtt-merchant-session-section-header">
        <i class="fas fa-hand-holding"></i>
        <h3 class="mtt-merchant-session-section-title">{{localize "mtt.sessions.buyerSide.title"}}</h3>
      </header>

      {{#if mtt.session.hasBuyerNegotiations}}
        <section class="mtt-merchant-session-negotiations mtt-merchant-session-buyer-negotiations">
          <header class="mtt-merchant-negotiation-section-header">
            <i class="fas fa-comments-dollar"></i>
            <h4>{{localize "mtt.sessions.negotiations.buyerTitle"}}</h4>
          </header>

          <ul class="mtt-merchant-negotiation-list">
            {{#each mtt.session.buyerNegotiations as |negotiation|}}
              <li class="mtt-merchant-negotiation-item mtt-merchant-negotiation-item-buyer" data-negotiation-id="{{negotiation.id}}">
                <div class="mtt-merchant-negotiation-head">
                  <img class="mtt-merchant-negotiation-img" src="{{negotiation.img}}" alt="{{negotiation.name}}" />
                  <div class="mtt-merchant-negotiation-main">
                    <strong>{{negotiation.name}}</strong>
                    {{#if negotiation.isFreePrice}}
                      <span class="mtt-merchant-negotiation-price-hint">
                        {{localize "mtt.sessions.negotiations.freePrice"}}
                        {{#if @root.mtt.isEditable}}
                          {{#if negotiation.hasMinimumPrice}}
                            {{localize "mtt.sessions.negotiations.freePriceMinimum" price=negotiation.minimumPriceLabel}}
                          {{else}}
                            {{localize "mtt.sessions.negotiations.freePriceNoMinimum"}}
                          {{/if}}
                        {{/if}}
                      </span>
                    {{else}}
                      <span>{{localize "mtt.sessions.negotiations.referencePrice"}} : {{negotiation.referenceUnitPriceLabel}}</span>
                    {{/if}}
                    <p class="mtt-merchant-negotiation-status">
                      <i class="fas fa-hourglass-half"></i>
                      {{#if negotiation.isBuyerTurn}}{{localize "mtt.sessions.negotiations.waitingBuyer"}}{{else}}{{localize "mtt.sessions.negotiations.waitingMerchant"}}{{/if}}
                    </p>
                  </div>
                </div>

                  <div class="mtt-merchant-negotiation-grid-header">
                    <span>{{localize "mtt.sessions.negotiations.sideShort"}}</span>
                    <span>{{localize "mtt.sessions.negotiations.quantityShort"}}</span>
                    <span>{{localize "mtt.sessions.negotiations.unitPriceShort"}}</span>
                    <span>{{localize "mtt.sessions.negotiations.totalShort"}}</span>
                    {{#unless negotiation.isFreePrice}}
                    <span>{{localize "mtt.sessions.negotiations.percentShort"}}</span>
                    {{/unless}}
                  </div>

                  {{#if negotiation.hasOffers}}
                    <ul class="mtt-merchant-negotiation-offers">
                      {{#each negotiation.offers as |offer|}}
                        <li class="mtt-merchant-negotiation-offer {{offer.sideClass}} mtt-merchant-negotiation-offer-submitted">
                          <span class="mtt-merchant-negotiation-offer-side">{{offer.sideLabel}}</span>
                          <span>{{offer.quantity}}</span>
                          <span>{{offer.unitPriceLabel}}</span>
                          <span>{{offer.totalPriceLabel}}</span>
                          {{#unless negotiation.isFreePrice}}
                          <span>{{offer.percentLabel}}</span>
                          {{/unless}}
                        </li>
                      {{/each}}
                    </ul>
                  {{/if}}

                  {{#if negotiation.hasDraft}}
                    <div
                      class="mtt-merchant-negotiation-offer mtt-merchant-negotiation-offer-draft {{negotiation.draftSideClass}}"
                      data-negotiation-draft
                      data-negotiation-id="{{negotiation.id}}"
                      data-reference-unit-price="{{negotiation.referenceUnitPriceValue}}"
                      data-is-free-price="{{#if negotiation.isFreePrice}}true{{else}}false{{/if}}"
                    >
                      <span class="mtt-merchant-negotiation-offer-side">{{negotiation.draftSideLabel}}</span>
                      <input class="mtt-merchant-negotiation-draft-field mtt-merchant-negotiation-draft-quantity" type="number" min="0" step="1" value="{{negotiation.draft.quantity}}" data-mtt-negotiation-field="quantity" data-negotiation-id="{{negotiation.id}}" data-tooltip="{{localize 'mtt.sessions.negotiations.quantity'}}" />
                      <input class="mtt-merchant-negotiation-draft-field mtt-merchant-negotiation-draft-unit-price" type="number" min="0" step="0.1" value="{{negotiation.draft.unitPriceValue}}" data-mtt-negotiation-field="unitPriceValue" data-negotiation-id="{{negotiation.id}}" data-tooltip="{{localize 'mtt.sessions.negotiations.unitPrice'}}" />
                      <input class="mtt-merchant-negotiation-draft-field mtt-merchant-negotiation-draft-total-price" type="number" min="0" step="0.1" value="{{negotiation.draft.totalPriceValue}}" data-mtt-negotiation-field="totalPriceValue" data-negotiation-id="{{negotiation.id}}" data-tooltip="{{localize 'mtt.sessions.negotiations.totalPrice'}}" />
                      {{#unless negotiation.isFreePrice}}
                      <input class="mtt-merchant-negotiation-draft-field mtt-merchant-negotiation-draft-percent" type="number" min="0" step="1" value="{{negotiation.draft.percentOfReference}}" data-mtt-negotiation-field="percentOfReference" data-negotiation-id="{{negotiation.id}}" data-tooltip="{{localize 'mtt.sessions.negotiations.percent'}}" />
                      {{/unless}}
                    </div>

                    <div class="mtt-merchant-negotiation-actions">
                      {{#if @root.mtt.isEditable}}
                        {{#if negotiation.isMerchantTurn}}
                          <button class="mtt-merchant-negotiation-action" type="button" data-action="submitNegotiationOffer" data-tooltip="{{localize 'mtt.sessions.negotiations.actions.submit'}}">
                            <i class="fas fa-paper-plane"></i>
                          </button>
                          <button class="mtt-merchant-negotiation-action" type="button" data-action="acceptNegotiationOffer" data-tooltip="{{localize 'mtt.sessions.negotiations.actions.accept'}}">
                            <i class="fas fa-check"></i>
                          </button>
                          <button class="mtt-merchant-negotiation-action" type="button" data-action="refuseNegotiationOffer" data-tooltip="{{localize 'mtt.sessions.negotiations.actions.refuse'}}">
                            <i class="fas fa-xmark"></i>
                          </button>
                        {{/if}}
                      {{else}}
                        {{#if negotiation.isBuyerTurn}}
                          <button class="mtt-merchant-negotiation-action" type="button" data-action="submitNegotiationOffer" data-tooltip="{{localize 'mtt.sessions.negotiations.actions.submit'}}">
                            <i class="fas fa-paper-plane"></i>
                          </button>
                          <button class="mtt-merchant-negotiation-action" type="button" data-action="acceptNegotiationOffer" data-tooltip="{{localize 'mtt.sessions.negotiations.actions.accept'}}">
                            <i class="fas fa-check"></i>
                          </button>
                          <button class="mtt-merchant-negotiation-action" type="button" data-action="refuseNegotiationOffer" data-tooltip="{{localize 'mtt.sessions.negotiations.actions.refuse'}}">
                            <i class="fas fa-xmark"></i>
                          </button>
                        {{/if}}
                      {{/if}}
                    </div>
                  {{/if}}
              </li>
            {{/each}}
          </ul>
        </section>
      {{/if}}

      <ol class="mtt-merchant-session-list">
        {{#if mtt.session.hasBuyerLines}}
          {{#if mtt.session.hasBuyerItems}}
          {{#each mtt.session.buyerItems as |item|}}
            <li class="mtt-merchant-session-item" data-session-side="buyer" data-session-item-id="{{item.id}}">
              <div>
                <img class="mtt-merchant-session-item-image" src="{{item.img}}" alt="{{item.name}}" />
              </div>

              <div class="mtt-merchant-session-item-name">
                <strong>{{item.name}}</strong>
              </div>

              <div class="mtt-merchant-session-item-quantity">
                  <span>
                    {{#if @root.permissions.canInteractWithSession}}
                      {{#unless @root.mtt.session.isSubmitted}}
                      <span class="mtt-merchant-session-item-controls">
                        <button
                          class="mtt-merchant-session-action"
                          type="button"
                          data-action="decreaseSessionItemQuantity"
                          data-tooltip="{{localize 'mtt.sessions.decreaseQuantity'}}"
                        ><i class="fas fa-minus"></i></button>
                        <input
                          class="mtt-merchant-session-quantity"
                          type="number"
                          min="0"
                          step="1"
                          value="{{item.quantity}}"
                          data-mtt-session-field="quantity"
                          data-session-side="buyer"
                          data-session-item-id="{{item.id}}"
                          data-tooltip="{{localize 'mtt.sessions.editQuantity'}}"
                        />
                        <button
                          class="mtt-merchant-session-action"
                          type="button"
                          data-action="increaseSessionItemQuantity"
                          data-tooltip="{{localize 'mtt.sessions.increaseQuantity'}}"
                        ><i class="fas fa-plus"></i></button>
                      </span>
                      {{else}}
                        <span>x {{item.quantity}}</span>
                      {{/unless}}
                    {{else}}
                      <span>x {{item.quantity}}</span>
                    {{/if}}
                  </span>
              </div>

              {{#if @root.permissions.canViewPrices}}
                <div class="mtt-merchant-session-item-total-price" data-tooltip="{{item.unitPriceLabel}}" data-tooltip-direction="UP">
                  <span>{{item.totalPriceLabel}}</span>
                </div>
              {{/if}}
            </li>
          {{/each}}
          {{/if}}
          {{#if @root.permissions.canViewPrices}}
            {{#if mtt.session.hasBuyerTotals}}
              <div class="mtt-merchant-session-total">
                <strong>{{localize "mtt.sessions.buyerTotal"}}</strong>
                <span>
                  {{#each mtt.session.buyerTotalByCurrency as |total|}}
                    <span class="mtt-merchant-session-item-total-price">{{total.totalPriceLabel}}</span>
                  {{/each}}
                </span>
              </div>
            {{/if}}
            {{#each mtt.session.buyerMoneyAdjustments as |adjustment|}}
              <li class="mtt-merchant-session-money-adjustment">
                <div><i class="fas fa-coins"></i></div>
                <div class="mtt-merchant-session-item-main">
                  <strong>{{adjustment.label}}</strong>
                </div>
                <div class="mtt-merchant-session-item-total-price">
                  <span>{{adjustment.amountLabel}}</span>
                </div>
              </li>
            {{/each}}
          {{/if}}
        {{else}}
          <li class="mtt-merchant-session-empty">{{localize "mtt.sessions.emptyBuyer"}}</li>
        {{/if}}
      </ol>

      
      </section>

      <section class="mtt-merchant-session-section mtt-merchant-session-side-seller" {{#if @root.permissions.canInteractWithSession}}{{#if mtt.session.canEdit}}{{#unless @root.mtt.session.isSubmitted}}data-mtt-session-seller-drop{{/unless}}{{/if}}{{/if}}>
      <header class="mtt-merchant-session-section-header">
        <i class="fas fa-handshake-angle"></i>
        <h3 class="mtt-merchant-session-section-title">{{localize "mtt.sessions.sellerSide.title"}}</h3>
      </header>

      {{#if mtt.session.hasSellerNegotiations}}
        <section class="mtt-merchant-session-negotiations mtt-merchant-session-seller-negotiations">
          <header class="mtt-merchant-negotiation-section-header">
            <i class="fas fa-handshake"></i>
            <h4>{{localize "mtt.sessions.negotiations.sellerTitle"}}</h4>
          </header>

          <ul class="mtt-merchant-negotiation-list">
            {{#each mtt.session.sellerNegotiations as |negotiation|}}
              <li class="mtt-merchant-negotiation-item mtt-merchant-negotiation-item-seller" data-negotiation-id="{{negotiation.id}}">
                <div class="mtt-merchant-negotiation-head">
                  <img class="mtt-merchant-negotiation-img" src="{{negotiation.img}}" alt="{{negotiation.name}}" />
                  <div class="mtt-merchant-negotiation-main">
                    <strong>{{negotiation.name}}</strong>
                    {{#if negotiation.isFreePrice}}
                      {{#if @root.mtt.isEditable}}
                        <span class="mtt-merchant-negotiation-price-hint">
                          {{#if negotiation.hasMinimumPrice}}
                            {{localize "mtt.sessions.negotiations.freePriceMinimum" price=negotiation.minimumPriceLabel}}
                          {{else}}
                            {{localize "mtt.sessions.negotiations.freePriceNoMinimum"}}
                          {{/if}}
                        </span>
                      {{/if}}
                    {{else}}
                      <span>{{localize "mtt.sessions.negotiations.referencePrice"}} : {{negotiation.referenceUnitPriceLabel}}</span>
                    {{/if}}
                    <p class="mtt-merchant-negotiation-status">
                      <i class="fas fa-hourglass-half"></i>
                      {{#if negotiation.isBuyerTurn}}{{localize "mtt.sessions.negotiations.waitingBuyer"}}{{else}}{{localize "mtt.sessions.negotiations.waitingMerchant"}}{{/if}}
                    </p>
                  </div>
                </div>

                  <div class="mtt-merchant-negotiation-grid-header">
                    <span class="mtt-merchant-negotiation-offer-side">{{localize "mtt.sessions.negotiations.sideShort"}}</span>
                    <span>{{localize "mtt.sessions.negotiations.quantityShort"}}</span>
                    <span>{{localize "mtt.sessions.negotiations.unitPriceShort"}}</span>
                    <span>{{localize "mtt.sessions.negotiations.totalShort"}}</span>
                    {{#unless negotiation.isFreePrice}}
                    <span>{{localize "mtt.sessions.negotiations.percentShort"}}</span>
                    {{/unless}}
                  </div>

                  {{#if negotiation.hasOffers}}
                    <ul class="mtt-merchant-negotiation-offers">
                      {{#each negotiation.offers as |offer|}}
                        <li class="mtt-merchant-negotiation-offer {{offer.sideClass}} mtt-merchant-negotiation-offer-submitted">
                          <span class="mtt-merchant-negotiation-offer-side">{{offer.sideLabel}}</span>
                          <span>{{offer.quantity}}</span>
                          <span>{{offer.unitPriceLabel}}</span>
                          <span>{{offer.totalPriceLabel}}</span>
                          {{#unless negotiation.isFreePrice}}
                          <span>{{offer.percentLabel}}</span>
                          {{/unless}}
                        </li>
                      {{/each}}
                    </ul>
                  {{/if}}

                  {{#if negotiation.hasDraft}}
                    <div
                      class="mtt-merchant-negotiation-offer mtt-merchant-negotiation-offer-draft {{negotiation.draftSideClass}}"
                      data-negotiation-draft
                      data-negotiation-id="{{negotiation.id}}"
                      data-reference-unit-price="{{negotiation.referenceUnitPriceValue}}"
                      data-is-free-price="{{#if negotiation.isFreePrice}}true{{else}}false{{/if}}"
                    >
                      <span class="mtt-merchant-negotiation-offer-side">{{negotiation.draftSideLabel}}</span>
                      <input class="mtt-merchant-negotiation-draft-field mtt-merchant-negotiation-draft-quantity" type="number" min="0" step="1" value="{{negotiation.draft.quantity}}" data-mtt-negotiation-field="quantity" data-negotiation-id="{{negotiation.id}}" data-tooltip="{{localize 'mtt.sessions.negotiations.quantity'}}" />
                      <input class="mtt-merchant-negotiation-draft-field mtt-merchant-negotiation-draft-unit-price" type="number" min="0" step="0.1" value="{{negotiation.draft.unitPriceValue}}" data-mtt-negotiation-field="unitPriceValue" data-negotiation-id="{{negotiation.id}}" data-tooltip="{{localize 'mtt.sessions.negotiations.unitPrice'}}" />
                      <input class="mtt-merchant-negotiation-draft-field mtt-merchant-negotiation-draft-total-price" type="number" min="0" step="0.1" value="{{negotiation.draft.totalPriceValue}}" data-mtt-negotiation-field="totalPriceValue" data-negotiation-id="{{negotiation.id}}" data-tooltip="{{localize 'mtt.sessions.negotiations.totalPrice'}}" />
                      {{#unless negotiation.isFreePrice}}
                      <input class="mtt-merchant-negotiation-draft-field mtt-merchant-negotiation-draft-percent" type="number" min="0" step="1" value="{{negotiation.draft.percentOfReference}}" data-mtt-negotiation-field="percentOfReference" data-negotiation-id="{{negotiation.id}}" data-tooltip="{{localize 'mtt.sessions.negotiations.percent'}}" />
                      {{/unless}}
                    </div>

                    <div class="mtt-merchant-negotiation-actions">
                      {{#if @root.mtt.isEditable}}
                        {{#if negotiation.isMerchantTurn}}
                          <button class="mtt-merchant-negotiation-action" type="button" data-action="submitNegotiationOffer" data-tooltip="{{localize 'mtt.sessions.negotiations.actions.submit'}}">
                            <i class="fas fa-paper-plane"></i>
                          </button>
                        {{/if}}
                        <button class="mtt-merchant-negotiation-action" type="button" data-action="acceptNegotiationOffer" data-tooltip="{{localize 'mtt.sessions.negotiations.actions.accept'}}">
                          <i class="fas fa-check"></i>
                        </button>
                        <button class="mtt-merchant-negotiation-action" type="button" data-action="refuseNegotiationOffer" data-tooltip="{{localize 'mtt.sessions.negotiations.actions.refuse'}}">
                          <i class="fas fa-xmark"></i>
                        </button>
                      {{else}}
                        {{#if negotiation.isBuyerTurn}}
                          <button class="mtt-merchant-negotiation-action" type="button" data-action="submitNegotiationOffer" data-tooltip="{{localize 'mtt.sessions.negotiations.actions.submit'}}">
                            <i class="fas fa-paper-plane"></i>
                          </button>
                          <button class="mtt-merchant-negotiation-action" type="button" data-action="acceptNegotiationOffer" data-tooltip="{{localize 'mtt.sessions.negotiations.actions.accept'}}">
                            <i class="fas fa-check"></i>
                          </button>
                          <button class="mtt-merchant-negotiation-action" type="button" data-action="refuseNegotiationOffer" data-tooltip="{{localize 'mtt.sessions.negotiations.actions.refuse'}}">
                            <i class="fas fa-xmark"></i>
                          </button>
                        {{/if}}
                      {{/if}}
                    </div>
                  {{/if}}
              </li>
            {{/each}}
          </ul>
        </section>
      {{/if}}

      <ol class="mtt-merchant-session-list">
        {{#if mtt.session.hasSellerLines}}
          {{#if mtt.session.hasSellerItems}}
          {{#each mtt.session.sellerItems as |item|}}
            <li class="mtt-merchant-session-item mtt-merchant-session-item-object" data-session-side="seller" data-session-item-id="{{item.id}}">
              <div>
                <img class="mtt-merchant-session-item-image" src="{{item.img}}" alt="{{item.name}}" />
              </div>

              <div class="mtt-merchant-session-item-main">
                <strong>{{item.name}}</strong>
              </div>

                <div class="mtt-merchant-session-item-quantity">
                  <span>
                    {{#if @root.permissions.canInteractWithSession}}
                      {{#unless @root.mtt.session.isSubmitted}}
                      <span class="mtt-merchant-session-item-controls">
                        <button
                          class="mtt-merchant-session-action"
                          type="button"
                          data-action="decreaseSessionItemQuantity"
                          data-tooltip="{{localize 'mtt.sessions.decreaseQuantity'}}"
                        ><i class="fas fa-minus"></i></button>
                        <input
                          class="mtt-merchant-session-quantity"
                          type="number"
                          min="0"
                          step="1"
                          value="{{item.quantity}}"
                          data-mtt-session-field="quantity"
                          data-session-side="seller"
                          data-session-item-id="{{item.id}}"
                          data-tooltip="{{localize 'mtt.sessions.editQuantity'}}"
                        />
                        <button
                          class="mtt-merchant-session-action"
                          type="button"
                          data-action="increaseSessionItemQuantity"
                          data-tooltip="{{localize 'mtt.sessions.increaseQuantity'}}"
                        ><i class="fas fa-plus"></i></button>
                      </span>
                      {{else}}
                        <span>x {{item.quantity}}</span>
                      {{/unless}}
                    {{else}}
                      <span>x {{item.quantity}}</span>
                    {{/if}}
                  </span>
                </div>
                {{#if @root.permissions.canViewPrices}}
                  <div class="mtt-merchant-session-item-total-price" data-tooltip="{{item.unitPriceLabel}}" data-tooltip-direction="UP">
                    <span>{{item.totalPriceLabel}}</span>
                  </div>
                {{/if}}
              </div>
            </li>
          {{/each}}
          {{/if}}
          {{#if @root.permissions.canViewPrices}}
            {{#if mtt.session.hasSellerTotals}}
              <div class="mtt-merchant-session-total mtt-merchant-session-side-total">
                <strong>{{localize "mtt.sessions.sellerTotal"}}</strong>
                <span>
                  {{#each mtt.session.sellerTotalByCurrency as |total|}}
                    <span>{{total.totalPriceLabel}}</span>
                  {{/each}}
                </span>
              </div>
            {{/if}}
            {{#each mtt.session.sellerMoneyAdjustments as |adjustment|}}
              <li class="mtt-merchant-session-money-adjustment">
                <div><i class="fas fa-coins"></i></div>
                <div class="mtt-merchant-session-item-main">
                  <strong>{{adjustment.label}}</strong>
                </div>
                <div class="mtt-merchant-session-item-total-price">
                  <span>{{adjustment.amountLabel}}</span>
                </div>
              </li>
            {{/each}}
          {{/if}}
        {{else}}
          <li class="mtt-merchant-session-empty">{{localize "mtt.sessions.emptySeller"}}</li>
        {{/if}}
      </ol>


        {{#if mtt.session.checkResult.checked}}
          <p class="mtt-merchant-session-check-status {{#if mtt.session.checkResult.canProceed}}mtt-merchant-session-check-info{{else}}mtt-merchant-session-check-error{{/if}}">
            {{#if mtt.session.checkResult.canProceed}}
              {{localize "mtt.sessions.check.success"}}
            {{else}}
              {{localize "mtt.sessions.check.failed"}}
            {{/if}}
          </p>

          {{#if mtt.session.checkResult.hasErrors}}
            <ul class="mtt-merchant-session-check-list">
              {{#each mtt.session.checkResult.errors as |message|}}
                <li class="mtt-merchant-session-check-message mtt-merchant-session-check-error">
                  {{#if message.icon}}<i class="fas {{message.icon}}"></i>{{/if}}
                  <span>{{message.text}}</span>
                </li>
              {{/each}}
            </ul>
          {{/if}}

          {{#if mtt.session.checkResult.hasWarnings}}
            <ul class="mtt-merchant-session-check-list">
              {{#each mtt.session.checkResult.warnings as |message|}}
                <li class="mtt-merchant-session-check-message mtt-merchant-session-check-warning">
                  {{#if message.icon}}<i class="fas {{message.icon}}"></i>{{/if}}
                  <span>{{message.text}}</span>
                </li>
              {{/each}}
            </ul>
          {{/if}}

          {{#if mtt.session.checkResult.hasInfos}}
            <ul class="mtt-merchant-session-check-list">
              {{#each mtt.session.checkResult.infos as |message|}}
                <li class="mtt-merchant-session-check-message mtt-merchant-session-check-info">
                  {{#if message.icon}}<i class="fas {{message.icon}}"></i>{{/if}}
                  <span>{{message.text}}</span>
                </li>
              {{/each}}
            </ul>
          {{/if}}
        {{else}}
          <p class="mtt-merchant-session-check-message mtt-merchant-session-check-info">
            <i class="fas fa-circle-info"></i>
            <span>{{localize "mtt.sessions.check.none"}}</span>
          </p>
        {{/if}}
      </section>
    {{else}}
      <section class="mtt-merchant-session-empty-state">
        <i class="fas fa-receipt"></i>
        <p>{{localize "mtt.sessions.authorizationCreatesSession"}}</p>
      </section>
    {{/if}}

 
    <section class="mtt-merchant-session-actions">
      {{#if mtt.session.hasSession}}
        {{#if mtt.session.isSubmitted}}
          <p class="mtt-merchant-session-submitted-message">{{localize "mtt.sessions.submittedMessage"}}</p>
        {{/if}}
        {{#if mtt.session.hasAnyItems}}
          {{#if @root.permissions.canInteractWithSession}}
              <button
                class="mtt-merchant-session-final-action delete"
                type="button"
                data-action="clearSessionDraft"
                data-tooltip="{{localize 'mtt.sessions.clearOnly'}}"
              >
                <i class="fas fa-rotate-left"></i>
              </button>
          {{/if}}
          <button class="mtt-merchant-session-final-action" type="button" data-action="previewSessionExecution" data-tooltip="{{localize 'mtt.sessions.actions.previewTooltip'}}">
            <i class="fas fa-clipboard-list"></i>
          </button>
          {{#if @root.permissions.canValidateOrRefuseSessions}}
            {{#if mtt.session.isSubmitted}}
              <button class="mtt-merchant-session-final-action" type="button" data-action="unlockSubmittedSession" data-tooltip="{{localize 'mtt.sessions.unlockSubmittedSession'}}">
                <i class="fas fa-thumbs-down"></i>
              </button>
            {{/if}}
            <button class="mtt-merchant-session-final-action valide" type="button" data-action="validateSessionTransaction" data-tooltip="{{localize 'mtt.sessions.actions.validateTooltip'}}">
              <i class="fas fa-check"></i>
            </button>
            <button class="mtt-merchant-session-final-action refuse" type="button" data-action="refuseSessionTransaction" data-tooltip="{{localize 'mtt.sessions.actions.refuseTooltip'}}">
              <i class="fas fa-xmark"></i>
            </button>
          {{else}}
            {{#if @root.permissions.canInteractWithSession}}
              {{#unless mtt.session.isSubmitted}}
                <button class="mtt-merchant-session-final-action" type="button" data-action="submitSession" data-tooltip="{{localize 'mtt.sessions.submitSession'}}">
                  <i class="fas fa-thumbs-up"></i>
                </button>
              {{/unless}}
            {{/if}}
          {{/if}}
        {{/if}}
      {{/if}}
    </section>

    {{#if mtt.session.hasRefusedNegotiations}}
      <section class="mtt-merchant-session-negotiations mtt-merchant-session-refused-negotiations">
        <header class="mtt-merchant-negotiation-section-header">
          <i class="fas fa-circle-xmark"></i>
          <h4>{{localize "mtt.sessions.negotiations.refusedTitle"}}</h4>
        </header>

        <ul class="mtt-merchant-negotiation-list">
          {{#each mtt.session.refusedNegotiations as |negotiation|}}
            <li class="mtt-merchant-negotiation-item mtt-merchant-negotiation-item-refused" data-negotiation-id="{{negotiation.id}}">
              <div class="mtt-merchant-negotiation-head">
                <img class="mtt-merchant-negotiation-img" src="{{negotiation.img}}" alt="{{negotiation.name}}" />
                <div class="mtt-merchant-negotiation-main">
                  <strong>{{negotiation.name}}</strong>
                  {{#if negotiation.isFreePrice}}
                    {{#if @root.mtt.isEditable}}
                      <span class="mtt-merchant-negotiation-price-hint">
                        {{#if negotiation.hasMinimumPrice}}
                          {{localize "mtt.sessions.negotiations.freePriceMinimum" price=negotiation.minimumPriceLabel}}
                        {{else}}
                          {{localize "mtt.sessions.negotiations.freePriceNoMinimum"}}
                        {{/if}}
                      </span>
                    {{/if}}
                  {{else}}
                    <span>{{localize "mtt.sessions.negotiations.referencePrice"}} : {{negotiation.referenceUnitPriceLabel}}</span>
                  {{/if}}
                  <p class="mtt-merchant-negotiation-status mtt-merchant-negotiation-status-refused">
                    <i class="fas fa-ban"></i>
                    {{localize "mtt.sessions.negotiations.refusedMessage"}}
                  </p>
                </div>
              </div>

                <div class="mtt-merchant-negotiation-grid-header">
                  <span class="mtt-merchant-negotiation-offer-side">{{localize "mtt.sessions.negotiations.sideShort"}}</span>
                  <span>{{localize "mtt.sessions.negotiations.quantityShort"}}</span>
                  <span>{{localize "mtt.sessions.negotiations.unitPriceShort"}}</span>
                  <span>{{localize "mtt.sessions.negotiations.totalShort"}}</span>
                  {{#unless negotiation.isFreePrice}}
                    <span>{{localize "mtt.sessions.negotiations.percentShort"}}</span>
                  {{/unless}}
                </div>

                {{#if negotiation.hasOffers}}
                  <ul class="mtt-merchant-negotiation-offers">
                    {{#each negotiation.offers as |offer|}}
                      <li class="mtt-merchant-negotiation-offer {{offer.sideClass}} mtt-merchant-negotiation-offer-submitted">
                        <span class="mtt-merchant-negotiation-offer-side">{{offer.sideLabel}}</span>
                        <span>{{offer.quantity}}</span>
                        <span>{{offer.unitPriceLabel}}</span>
                        <span>{{offer.totalPriceLabel}}</span>
                        {{#unless negotiation.isFreePrice}}
                        <span>{{offer.percentLabel}}</span>
                        {{/unless}}
                      </li>
                    {{/each}}
                  </ul>
                {{/if}}
              </li>
          {{/each}}
        </ul>
      </section>
    {{/if}}
    </section>
  {{/if}}

  {{!-- MTT storage — emplacement futur de la session dépôt/retrait --}}
  {{#if isStorage}}
    <section class="mtt-merchant-session">
      <section class="mtt-merchant-session-empty-state">
        <i class="fas fa-box-archive"></i>
        <p>{{localize "mtt.storage.placeholder.session"}}</p>
      </section>
    </section>
  {{/if}}
</aside>
