<aside class="mtt-merchant-session-sidebar">
  <section class="mtt-merchant-session">
    <header class="mtt-merchant-session-header">
      <div class="mtt-merchant-session-title-block">
        <h2 class="mtt-merchant-session-title">{{localize "mtt.sessions.title"}}</h2>
      </div>
      {{#if mtt.session.hasSession}}
        <button
          class="mtt-merchant-session-action"
          type="button"
          data-action="clearSessionDraft"
          data-tooltip="{{localize 'mtt.sessions.clearOnly'}}"
        >
          <i class="fas fa-rotate-left"></i>
        </button>
      {{/if}}
    </header>

    {{#if mtt.session.hasSession}}
      <section class="mtt-merchant-session-section mtt-merchant-session-side-buyer">
      <header class="mtt-merchant-session-section-header">
        <i class="fas fa-hand-holding"></i>
        <h3 class="mtt-merchant-session-section-title">{{localize "mtt.sessions.buyerSide.title"}}</h3>
      </header>

      <ol class="mtt-merchant-session-list">
        {{#if mtt.session.hasBuyerLines}}
          {{#if mtt.session.hasBuyerItems}}
          {{#each mtt.session.buyerItems as |item|}}
            <li class="mtt-merchant-session-item" data-session-side="buyer" data-session-item-id="{{item.id}}">
              {{#if item.img}}
                <img class="mtt-merchant-session-item-image" src="{{item.img}}" alt="{{item.name}}" />
              {{/if}}

              <div class="mtt-merchant-session-item-main">
                <strong>{{item.name}}</strong>
                <div class="mtt-merchant-session-item-meta">
                  <span class="mtt-session-item-tag">{{item.sourceLabel}}</span>
                  {{#if item.isFreePrice}}
                    <span class="mtt-session-item-tag mtt-session-item-tag-free-price" data-tooltip="{{localize 'mtt.price.freePriceTooltip'}}">
                      <i class="fas fa-scale-balanced"></i>
                    </span>
                  {{/if}}
                  {{#if item.hasLimitedQuantity}}
                    <span class="mtt-merchant-session-available">
                      {{localize "mtt.sessions.item.available"}} {{item.availableQuantityLabel}}
                    </span>
                  {{/if}}
                  <span>
                    <span class="mtt-merchant-session-item-controls">
                      <button
                        class="mtt-merchant-session-action"
                        type="button"
                        data-action="decreaseSessionItemQuantity"
                        data-tooltip="{{localize 'mtt.sessions.decreaseQuantity'}}"
                        {{#unless mtt.session.canEdit}}disabled{{/unless}}
                      ><i class="fas fa-minus"></i></button>
                      <input
                        class="mtt-merchant-session-quantity"
                        type="number"
                        min="0"
                        step="1"
                        value="{{item.quantity}}"
                        data-mtt-session-field="quantity"
                        data-session-side="buyer"
                        data-session-item-id="{{item.id}}"
                        data-tooltip="{{localize 'mtt.sessions.editQuantity'}}"
                        {{#unless mtt.session.canEdit}}disabled{{/unless}}
                      />
                      <button
                        class="mtt-merchant-session-action"
                        type="button"
                        data-action="increaseSessionItemQuantity"
                        data-tooltip="{{localize 'mtt.sessions.increaseQuantity'}}"
                        {{#unless mtt.session.canEdit}}disabled{{/unless}}
                      ><i class="fas fa-plus"></i></button>
                    </span>
                  </span>
                </div>
                <div class="mtt-merchant-session-item-meta">
                  {{#if item.isFreePrice}}
                    <span>{{localize "mtt.price.proposedPrice"}} {{item.unitPriceLabel}}</span>
                    {{#if @root.mtt.canEditMerchant}}
                      {{#if item.hasMinimumPrice}}
                        <span class="mtt-session-minimum-price-hint" data-tooltip="{{item.minimumPriceLabel}}">
                          <i class="fas fa-scale-balanced"></i>
                          {{localize "mtt.price.minimumPrice"}}
                        </span>
                      {{/if}}
                    {{/if}}
                  {{else}}
                    <span>{{localize "mtt.sessions.item.unitPrice"}} {{item.unitPriceLabel}}</span>
                  {{/if}}
                  <span>{{localize "mtt.sessions.item.totalPrice"}} {{item.totalPriceLabel}}</span>
                </div>
              </div>
            </li>
          {{/each}}
          {{/if}}
          {{#each mtt.session.buyerMoneyAdjustments as |adjustment|}}
            <li class="mtt-merchant-session-money-adjustment">
              <i class="fas fa-coins"></i>
              <div class="mtt-merchant-session-item-main">
                <strong>{{adjustment.label}}</strong>
                <div class="mtt-merchant-session-item-meta">
                  <span>{{adjustment.amountLabel}}</span>
                </div>
              </div>
            </li>
          {{/each}}
        {{else}}
          <li class="mtt-merchant-session-empty">{{localize "mtt.sessions.emptyBuyer"}}</li>
        {{/if}}
      </ol>

      {{#if mtt.session.hasBuyerTotals}}
        <div class="mtt-merchant-session-total">
          <strong>{{localize "mtt.sessions.buyerTotal"}}</strong>
          <span>
            {{#each mtt.session.buyerTotalByCurrency as |total|}}
              <span>{{total.totalPriceLabel}}</span>
            {{/each}}
          </span>
        </div>
      {{/if}}
      </section>

      <section class="mtt-merchant-session-section mtt-merchant-session-side-seller" data-mtt-session-seller-drop>
      <header class="mtt-merchant-session-section-header">
        <i class="fas fa-handshake-angle"></i>
        <h3 class="mtt-merchant-session-section-title">{{localize "mtt.sessions.sellerSide.title"}}</h3>
      </header>

      <ol class="mtt-merchant-session-list">
        {{#if mtt.session.hasSellerLines}}
          {{#if mtt.session.hasSellerItems}}
          {{#each mtt.session.sellerItems as |item|}}
            <li class="mtt-merchant-session-item mtt-merchant-session-item-object" data-session-side="seller" data-session-item-id="{{item.id}}">
              {{#if item.img}}
                <img class="mtt-merchant-session-item-image" src="{{item.img}}" alt="{{item.name}}" />
              {{/if}}

              <div class="mtt-merchant-session-item-main">
                <strong>{{item.name}}</strong>
                <div class="mtt-merchant-session-item-meta">
                  <span class="mtt-session-item-tag">{{item.sourceLabel}}</span>
                  {{#if item.hasLimitedQuantity}}
                    <span class="mtt-merchant-session-available">
                      {{localize "mtt.sessions.item.available"}} {{item.availableQuantityLabel}}
                    </span>
                  {{/if}}
                  <span>
                    <span class="mtt-merchant-session-item-controls">
                      <button
                        class="mtt-merchant-session-action"
                        type="button"
                        data-action="decreaseSessionItemQuantity"
                        data-tooltip="{{localize 'mtt.sessions.decreaseQuantity'}}"
                        {{#unless mtt.session.canEdit}}disabled{{/unless}}
                      ><i class="fas fa-minus"></i></button>
                      <input
                        class="mtt-merchant-session-quantity"
                        type="number"
                        min="0"
                        step="1"
                        value="{{item.quantity}}"
                        data-mtt-session-field="quantity"
                        data-session-side="seller"
                        data-session-item-id="{{item.id}}"
                        data-tooltip="{{localize 'mtt.sessions.editQuantity'}}"
                        {{#unless mtt.session.canEdit}}disabled{{/unless}}
                      />
                      <button
                        class="mtt-merchant-session-action"
                        type="button"
                        data-action="increaseSessionItemQuantity"
                        data-tooltip="{{localize 'mtt.sessions.increaseQuantity'}}"
                        {{#unless mtt.session.canEdit}}disabled{{/unless}}
                      ><i class="fas fa-plus"></i></button>
                    </span>
                  </span>
                </div>
                <div class="mtt-merchant-session-item-meta">
                  <span>{{localize "mtt.sessions.sellerUnitValue"}} {{item.unitPriceLabel}}</span>
                  <span>{{localize "mtt.sessions.item.totalPrice"}} {{item.totalPriceLabel}}</span>
                </div>
              </div>
            </li>
          {{/each}}
          {{/if}}
          {{#each mtt.session.sellerMoneyAdjustments as |adjustment|}}
            <li class="mtt-merchant-session-money-adjustment">
              <i class="fas fa-coins"></i>
              <div class="mtt-merchant-session-item-main">
                <strong>{{adjustment.label}}</strong>
                <div class="mtt-merchant-session-item-meta">
                  <span>{{adjustment.amountLabel}}</span>
                </div>
              </div>
            </li>
          {{/each}}
        {{else}}
          <li class="mtt-merchant-session-empty">{{localize "mtt.sessions.emptySeller"}}</li>
        {{/if}}
      </ol>

      {{#if mtt.session.hasSellerTotals}}
        <div class="mtt-merchant-session-total mtt-merchant-session-side-total">
          <strong>{{localize "mtt.sessions.sellerTotal"}}</strong>
          <span>
            {{#each mtt.session.sellerTotalByCurrency as |total|}}
              <span>{{total.totalPriceLabel}}</span>
            {{/each}}
          </span>
        </div>
      {{/if}}

      <div class="mtt-merchant-session-seller-placeholder mtt-merchant-session-seller-drop">
        <i class="fas fa-arrow-down"></i>
        <p>{{localize "mtt.sessions.sellerDropPlaceholder"}}</p>
      </div>
      </section>

      <section class="mtt-merchant-session-summary">
        <h3 class="mtt-merchant-session-section-title">{{localize "mtt.sessions.summary"}}</h3>
        <div class="mtt-merchant-session-summary-row">
          <span>{{localize "mtt.sessions.buyerTotal"}}</span>
          <strong>
            {{#if mtt.session.hasBuyerTotals}}
              {{#each mtt.session.buyerTotalByCurrency as |total|}}
                <span>{{total.totalPriceLabel}}</span>
              {{/each}}
            {{else}}
              <span>0</span>
            {{/if}}
          </strong>
        </div>
        <div class="mtt-merchant-session-summary-row">
          <span>{{localize "mtt.sessions.sellerTotal"}}</span>
          <strong>
            {{#if mtt.session.hasSellerTotals}}
              {{#each mtt.session.sellerTotalByCurrency as |total|}}
                <span>{{total.totalPriceLabel}}</span>
              {{/each}}
            {{else}}
              <span>0</span>
            {{/if}}
          </strong>
        </div>
        {{#if mtt.session.hasMoneyAdjustments}}
          {{#each mtt.session.moneyAdjustments as |adjustment|}}
            <div class="mtt-merchant-session-summary-row">
              <span>{{adjustment.label}}</span>
              <strong>{{adjustment.amountLabel}}</strong>
            </div>
          {{/each}}
        {{else}}
          {{#if mtt.session.isBalanced}}
            <p class="mtt-merchant-session-balanced">{{localize "mtt.sessions.balanced"}}</p>
          {{/if}}
        {{/if}}
      </section>

      <section class="mtt-merchant-session-check">
        <header class="mtt-merchant-session-check-header">
          <i class="fas fa-clipboard-check"></i>
          <h3 class="mtt-merchant-session-section-title">{{localize "mtt.sessions.check.title"}}</h3>
        </header>

        {{#if mtt.session.checkResult.checked}}
          <p class="mtt-merchant-session-check-status {{#if mtt.session.checkResult.canProceed}}mtt-merchant-session-check-info{{else}}mtt-merchant-session-check-error{{/if}}">
            {{#if mtt.session.checkResult.canProceed}}
              {{localize "mtt.sessions.check.success"}}
            {{else}}
              {{localize "mtt.sessions.check.failed"}}
            {{/if}}
          </p>

          {{#if mtt.session.checkResult.hasErrors}}
            <ul class="mtt-merchant-session-check-list">
              {{#each mtt.session.checkResult.errors as |message|}}
                <li class="mtt-merchant-session-check-message mtt-merchant-session-check-error">
                  {{#if message.icon}}<i class="fas {{message.icon}}"></i>{{/if}}
                  <span>{{message.text}}</span>
                </li>
              {{/each}}
            </ul>
          {{/if}}

          {{#if mtt.session.checkResult.hasWarnings}}
            <ul class="mtt-merchant-session-check-list">
              {{#each mtt.session.checkResult.warnings as |message|}}
                <li class="mtt-merchant-session-check-message mtt-merchant-session-check-warning">
                  {{#if message.icon}}<i class="fas {{message.icon}}"></i>{{/if}}
                  <span>{{message.text}}</span>
                </li>
              {{/each}}
            </ul>
          {{/if}}

          {{#if mtt.session.checkResult.hasInfos}}
            <ul class="mtt-merchant-session-check-list">
              {{#each mtt.session.checkResult.infos as |message|}}
                <li class="mtt-merchant-session-check-message mtt-merchant-session-check-info">
                  {{#if message.icon}}<i class="fas {{message.icon}}"></i>{{/if}}
                  <span>{{message.text}}</span>
                </li>
              {{/each}}
            </ul>
          {{/if}}
        {{else}}
          <p class="mtt-merchant-session-check-message mtt-merchant-session-check-info">
            <i class="fas fa-circle-info"></i>
            <span>{{localize "mtt.sessions.check.none"}}</span>
          </p>
        {{/if}}
      </section>
    {{else}}
      <section class="mtt-merchant-session-empty-state">
        <i class="fas fa-receipt"></i>
        <p>{{localize "mtt.sessions.authorizationCreatesSession"}}</p>
      </section>
    {{/if}}

    <div class="mtt-merchant-session-placeholder">
      <i class="fas fa-circle-info"></i>
      <p class="mtt-merchant-session-placeholder-text">{{localize "mtt.sessions.moneyAdjustmentHint"}}</p>
    </div>

    <p class="mtt-merchant-session-notice">{{localize "mtt.sessions.persistentDraftNotice"}}</p>

    <footer class="mtt-merchant-session-actions">
      {{#if mtt.session.hasSession}}
        {{#if mtt.session.hasAnyItems}}
          <button class="mtt-merchant-session-action" type="button" data-action="previewSessionExecution" data-tooltip="{{localize 'mtt.sessions.actions.previewTooltip'}}">
            <i class="fas fa-clipboard-list"></i>
          </button>
        {{/if}}
        {{#if mtt.session.canEdit}}
          <button class="mtt-merchant-session-action" type="button" data-action="requestSessionDecision" data-tooltip="{{localize 'mtt.sessions.actions.requestDecisionTooltip'}}">
            <i class="fas fa-triangle-exclamation"></i>
          </button>
        {{/if}}
        {{#if @root.mtt.canConfigureMerchant}}
          <button class="mtt-merchant-session-action" type="button" data-action="validateSessionTransaction" data-tooltip="{{localize 'mtt.sessions.actions.validateTooltip'}}">
            <i class="fas fa-check"></i>
          </button>
          <button class="mtt-merchant-session-action" type="button" data-action="refuseSessionTransaction" data-tooltip="{{localize 'mtt.sessions.actions.refuseTooltip'}}">
            <i class="fas fa-xmark"></i>
          </button>
        {{/if}}
      {{/if}}
    </footer>
  </section>
</aside>
