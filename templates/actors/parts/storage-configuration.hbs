{{!-- MTT storage — contenu de configuration propre au stockage --}}
<section class="mtt-merchant-configuration">
  <section class="mtt-merchant-configuration-section mtt-storage-trade-with-merchant">
    <h2 class="mtt-merchant-section-title">{{localize "mtt.storage.tradeWithMerchant.title"}}</h2>
    <p class="mtt-merchant-configuration-hint">{{localize "mtt.storage.tradeWithMerchant.description"}}</p>

    {{#if storageTradeWithMerchant.hasActors}}
      <div class="mtt-storage-trade-responsibles">
        {{#each storageTradeWithMerchant.actors as |actor|}}
          <button
            type="button"
            class="{{actor.cardClasses}}"
            data-action="toggleStorageTradeResponsibleActor"
            data-actor-uuid="{{actor.actorUuid}}"
            data-tooltip="{{actor.tooltip}}"
            data-tooltip-direction="UP"
            {{#unless @root.storageTradeWithMerchant.canConfigure}}disabled{{/unless}}
          >
            <img
              class="mtt-storage-trade-responsible-card-image"
              src="{{actor.actorImg}}"
              alt="{{actor.actorName}}"
            />
            <span class="mtt-storage-trade-responsible-card-name">{{actor.actorName}}</span>
          </button>
        {{/each}}
      </div>
    {{else}}
      <p class="mtt-merchant-configuration-empty">{{localize "mtt.storage.tradeWithMerchant.noActors"}}</p>
    {{/if}}
  </section>

  <section class="mtt-merchant-configuration-section">
    <h2 class="mtt-merchant-section-title">{{localize "mtt.storage.configuration.walletSection"}}</h2>

    {{#if mtt.walletCurrencies.length}}
      <div class="mtt-merchant-wallet-grid">
        {{#each mtt.walletCurrencies as |currency|}}
          <label class="mtt-merchant-wallet-currency">
            <span class="mtt-merchant-wallet-currency-code">{{currency.label}}</span>
            {{#if @root.mtt.canEditMerchant}}
              <input
                class="mtt-merchant-wallet-currency-input"
                type="number"
                min="0"
                step="1"
                value="{{currency.amount}}"
                data-mtt-wallet-currency="{{currency.id}}"
              />
            {{else}}
              <span class="mtt-merchant-wallet-readonly">{{currency.amount}}</span>
            {{/if}}
          </label>
        {{/each}}
      </div>
    {{else}}
      <p class="mtt-merchant-configuration-empty">{{localize "mtt.configuration.walletNoCurrencies"}}</p>
    {{/if}}
  </section>
</section>
