<div class="mtt-config-body">
  <form class="mtt-config-form">

    {{! Section : Chemins des objets }}
    <section class="mtt-config-section">
      <h3 class="mtt-config-section-title">{{localize
          "mtt.config.sections.items"
        }}</h3>

      <div class="mtt-config-field">
        <label>{{localize "mtt.settings.itemPriceValuePath.name"}}</label>
        <input
          type="text"
          name="itemPriceValuePath"
          value="{{itemPriceValuePath}}"
          placeholder="system.price.value"
        />
        <p class="mtt-config-hint">{{localize
            "mtt.settings.itemPriceValuePath.hint"
          }}</p>
      </div>

      <div class="mtt-config-field">
        <label>{{localize "mtt.settings.itemPriceCurrencyPath.name"}}</label>
        <input
          type="text"
          name="itemPriceCurrencyPath"
          value="{{itemPriceCurrencyPath}}"
          placeholder="system.price.currency"
        />
        <p class="mtt-config-hint">{{localize
            "mtt.settings.itemPriceCurrencyPath.hint"
          }}</p>
      </div>

      <div class="mtt-config-field">
        <label>{{localize "mtt.settings.itemQuantityPath.name"}}</label>
        <input
          type="text"
          name="itemQuantityPath"
          value="{{itemQuantityPath}}"
          placeholder="system.quantity"
        />
        <p class="mtt-config-hint">{{localize
            "mtt.settings.itemQuantityPath.hint"
        }}</p>
      </div>

      <div class="mtt-config-field">
        <label>{{localize "mtt.settings.deliveryItemQuantityPath.name"}}</label>
        <input
          type="text"
          name="deliveryItemQuantityPath"
          value="{{deliveryItemQuantityPath}}"
          placeholder="system.quantity.value"
        />
        <p class="mtt-config-hint">{{localize
            "mtt.settings.deliveryItemQuantityPath.hint"
          }}</p>
      </div>

      <div class="mtt-config-field">
        <label>{{localize "mtt.settings.deliveryItemMaxQuantityPath.name"}}</label>
        <input
          type="text"
          name="deliveryItemMaxQuantityPath"
          value="{{deliveryItemMaxQuantityPath}}"
          placeholder="system.quantity.max"
        />
        <p class="mtt-config-hint">{{localize
            "mtt.settings.deliveryItemMaxQuantityPath.hint"
        }}</p>
      </div>

      <label class="mtt-config-checkbox-field">
        <input
          type="checkbox"
          name="allowExtendedItemMerge"
          {{#if allowExtendedItemMerge}}checked{{/if}}
        />
        <span>{{localize "mtt.settings.allowExtendedItemMerge.name"}}</span>
      </label>
      <p class="mtt-config-hint">{{localize
          "mtt.settings.allowExtendedItemMerge.hint"
        }}</p>

      <div class="mtt-config-field">
        <label>{{localize "mtt.settings.itemDescriptionPath.name"}}</label>
        <input
          type="text"
          name="itemDescriptionPath"
          value="{{itemDescriptionPath}}"
          placeholder="system.description.value"
        />
        <p class="mtt-config-hint">{{localize
            "mtt.settings.itemDescriptionPath.hint"
          }}</p>
      </div>

      <div class="mtt-config-field">
        <label>{{localize "mtt.settings.allowedProductTypes.name"}}</label>
        <input
          type="text"
          name="allowedProductTypes"
          value="{{allowedProductTypes}}"
        />
        <p class="mtt-config-hint">{{localize
            "mtt.settings.allowedProductTypes.hint"
          }}</p>
      </div>

      <div class="mtt-config-field">
        <label>{{localize "mtt.settings.allowedServiceTypes.name"}}</label>
        <input
          type="text"
          name="allowedServiceTypes"
          value="{{allowedServiceTypes}}"
        />
        <p class="mtt-config-hint">{{localize
            "mtt.settings.allowedServiceTypes.hint"
          }}</p>
      </div>
    </section>

    {{! Section : Catégories automatiques }}
    <section class="mtt-config-section">
      <h3 class="mtt-config-section-title">{{localize
          "mtt.configuration.automaticCategories"
        }}</h3>

      <div class="mtt-config-field">
        <label>{{localize "mtt.settings.itemCategoryPaths.name"}}</label>
        <textarea
          name="itemCategoryPaths"
          class="mtt-config-textarea"
          placeholder="{{localize 'mtt.configuration.categoryPathsPlaceholder'}}"
        >{{itemCategoryPaths}}</textarea>
        <p class="mtt-config-hint">{{localize
            "mtt.settings.itemCategoryPaths.hint"
          }}</p>
      </div>

      <label class="mtt-config-checkbox-field">
        <input
          type="checkbox"
          name="useItemTypeAsCategoryFallback"
          {{#if useItemTypeAsCategoryFallback}}checked{{/if}}
        />
        <span>{{localize "mtt.settings.useItemTypeAsCategoryFallback.name"}}</span>
      </label>
      <p class="mtt-config-hint">{{localize
          "mtt.settings.useItemTypeAsCategoryFallback.hint"
        }}</p>

      <div class="mtt-config-field">
        <label>{{localize "mtt.settings.categoryLabelMap.name"}}</label>
        <textarea
          name="categoryLabelMap"
          class="mtt-config-textarea"
          placeholder="{{localize 'mtt.configuration.categoryLabelMapPlaceholder'}}"
        >{{categoryLabelMap}}</textarea>
        <p class="mtt-config-hint">{{localize
            "mtt.settings.categoryLabelMap.hint"
          }}</p>
      </div>
    </section>

    {{! Section : Devises et conversion }}
    <section class="mtt-config-section">
      <h3 class="mtt-config-section-title">{{localize
          "mtt.config.sections.currencies"
        }}</h3>
      <p class="mtt-config-explanation">{{localize
          "mtt.config.currencies.explanation"
        }}</p>

      <div class="mtt-config-currencies-header">
        <span>{{localize "mtt.config.currencies.columns.name"}}</span>
        <span>{{localize "mtt.config.currencies.columns.abbreviation"}}</span>
        <span>{{localize "mtt.config.currencies.columns.actorPath"}}</span>
        <span>{{localize "mtt.config.currencies.columns.rate"}}</span>
        <span></span>
      </div>

      {{#each currencies as |currency|}}
        <div class="mtt-config-currency-row" data-currency-id="{{currency.id}}">
          <input
            type="text"
            class="mtt-config-currency-input"
            data-mtt-currency-field="name"
            value="{{currency.name}}"
            placeholder="{{localize 'mtt.config.currencies.namePlaceholder'}}"
          />
          <input
            type="text"
            class="mtt-config-currency-input mtt-config-currency-abbr"
            data-mtt-currency-field="abbreviation"
            value="{{currency.abbreviation}}"
            placeholder="{{localize 'mtt.config.currencies.abbrPlaceholder'}}"
          />
          <input
            type="text"
            class="mtt-config-currency-input mtt-config-currency-path"
            data-mtt-currency-field="actorPath"
            value="{{currency.actorPath}}"
            placeholder="{{localize 'mtt.config.currencies.pathPlaceholder'}}"
          />
          <input
            type="number"
            class="mtt-config-currency-input mtt-config-currency-rate"
            data-mtt-currency-field="rate"
            value="{{currency.rate}}"
            min="0.0001"
            step="0.0001"
            placeholder="{{localize 'mtt.config.currencies.ratePlaceholder'}}"
          />
          <button
            type="button"
            class="mtt-config-currency-delete"
            data-action="deleteCurrency"
            data-currency-id="{{currency.id}}"
            data-tooltip="{{localize 'mtt.config.currencies.delete'}}"
          >
            <i class="fas fa-trash"></i>
          </button>
        </div>
      {{else}}
        <p class="mtt-config-currencies-empty">{{localize
            "mtt.config.currencies.empty"
          }}</p>
      {{/each}}

      <button
        type="button"
        class="mtt-config-btn mtt-config-btn--add"
        data-action="addCurrency"
        data-tooltip="{{localize 'mtt.config.currencies.add'}}"
      >
        <i class="fas fa-plus"></i>
        {{localize "mtt.config.currencies.add"}}
      </button>
    </section>

    {{! Footer }}
    <footer class="mtt-config-footer">
      <button
        type="button"
        class="mtt-config-btn mtt-config-btn--save"
        data-action="save"
        data-tooltip="{{localize 'mtt.config.save'}}"
      >
        <i class="fas fa-floppy-disk"></i>
        {{localize "mtt.config.save"}}
      </button>
      <button
        type="button"
        class="mtt-config-btn mtt-config-btn--cancel"
        data-action="cancel"
        data-tooltip="{{localize 'mtt.config.cancel'}}"
      >
        <i class="fas fa-xmark"></i>
        {{localize "mtt.config.cancel"}}
      </button>
    </footer>

  </form>
</div>
