<section class="mtt-config">
  <form class="mtt-config-form">
    <section class="mtt-config-section mtt-config-import-export">
      <h2 class="mtt-config-section-title">{{localize "mtt.config.importExport.title"}}</h2>
      <p class="mtt-config-section-hint">{{localize "mtt.config.importExport.hint"}}</p>
      <div class="mtt-config-import-export-actions">
        <button type="button" class="mtt-config-btn" data-action="importConfiguration">
          <i class="fas fa-file-import"></i>
          {{localize "mtt.config.importExport.import"}}
        </button>
        <button type="button" class="mtt-config-btn" data-action="exportConfiguration">
          <i class="fas fa-file-export"></i>
          {{localize "mtt.config.importExport.export"}}
        </button>
      </div>
    </section>

    <section class="mtt-config-actor-types-global">
    <section class="mtt-config-section">
      <h2 class="mtt-config-section-title">{{localize "mtt.config.actorTypes.title"}}</h2>
      <p class="mtt-config-section-hint">{{localize "mtt.config.actorTypes.hint"}}</p>

      {{#if availableActorTypes.length}}
        <div class="mtt-config-actor-types">
          {{#each availableActorTypes as |actorType|}}
            <label class="mtt-config-checkbox-field">
              <input
                type="checkbox"
                name="allowedMerchantActorTypes"
                value="{{actorType.value}}"
                {{#if actorType.checked}}checked{{/if}}
              />
              <span>{{actorType.label}}</span>
            </label>
          {{/each}}
        </div>
        {{#unless hasAllowedActorTypes}}
          <p class="notification warning">{{localize "mtt.config.actorTypes.noneSelected"}}</p>
        {{/unless}}
      {{else}}
        <p class="mtt-config-section-hint">{{localize "mtt.config.actorTypes.noneAvailable"}}</p>
      {{/if}}
    </section>

    <section class="mtt-config-section">
      <h2 class="mtt-config-section-title">{{localize "mtt.config.storageActorTypes.title"}}</h2>
      <p class="mtt-config-section-hint">{{localize "mtt.config.storageActorTypes.hint"}}</p>

      {{#if availableStorageActorTypes.length}}
        <div class="mtt-config-actor-types">
          {{#each availableStorageActorTypes as |actorType|}}
            <label class="mtt-config-checkbox-field">
              <input
                type="checkbox"
                name="allowedStorageActorTypes"
                value="{{actorType.value}}"
                {{#if actorType.checked}}checked{{/if}}
              />
              <span>{{actorType.label}}</span>
            </label>
          {{/each}}
        </div>
        {{#unless hasAllowedStorageActorTypes}}
          <p class="notification warning">{{localize "mtt.config.storageActorTypes.noneSelected"}}</p>
        {{/unless}}
      {{else}}
        <p class="mtt-config-section-hint">{{localize "mtt.config.storageActorTypes.noneAvailable"}}</p>
      {{/if}}
    </section>
    </section>


    <section class="mtt-config-section mtt-config-permissions">
      <h2 class="mtt-config-section-title">{{localize "mtt.permissions.merchant.config.title"}}</h2>
      <p class="mtt-config-section-hint">{{localize "mtt.permissions.merchant.config.hint"}}</p>

      <div class="mtt-permissions-table">
        <div class="mtt-permissions-table-head">
          <span>{{localize "mtt.permissions.merchant.columns.permission"}}</span>
          <span>{{localize "mtt.permissions.merchant.columns.limited"}}</span>
          <span>{{localize "mtt.permissions.merchant.columns.observer"}}</span>
          <span>{{localize "mtt.permissions.merchant.columns.owner"}}</span>
        </div>

        <div class="mtt-permissions-table-body">
          {{#each merchantPermissionRows as |permission|}}
            <div class="mtt-permissions-row">
              <div class="mtt-permissions-label">
                <i
                  class="fas fa-circle-info mtt-config-info-icon"
                  data-tooltip="{{localize permission.hint}}"
                  aria-hidden="true"
                ></i>
                <span>{{localize permission.label}}</span>
              </div>
              <label class="mtt-permissions-check">
                {{#if permission.canConfigureLimited}}
                  <input
                    type="checkbox"
                    name="merchantPermissionProfiles.limited.{{permission.key}}"
                    {{#if permission.limited}}checked{{/if}}
                  />
                {{else}}
                  <span class="mtt-permission-unavailable" aria-hidden="true">—</span>
                {{/if}}
              </label>
              <label class="mtt-permissions-check">
                {{#if permission.canConfigureObserver}}
                  <input
                    type="checkbox"
                    name="merchantPermissionProfiles.observer.{{permission.key}}"
                    {{#if permission.observer}}checked{{/if}}
                  />
                {{else}}
                  <span class="mtt-permission-unavailable" aria-hidden="true">—</span>
                {{/if}}
              </label>
              <label class="mtt-permissions-check">
                {{#if permission.canConfigureOwner}}
                  <input
                    type="checkbox"
                    name="merchantPermissionProfiles.owner.{{permission.key}}"
                    {{#if permission.owner}}checked{{/if}}
                  />
                {{else}}
                  <span class="mtt-permission-unavailable" aria-hidden="true">—</span>
                {{/if}}
              </label>
            </div>
          {{/each}}
        </div>
      </div>
    </section>

    <section class="mtt-config-section">
      <h2 class="mtt-config-section-title">{{localize "mtt.config.sections.items"}}</h2>

      <div class="mtt-config-grid">
        <div class="mtt-config-field">
          <div class="mtt-config-field-header">
            <label class="mtt-config-field-label" for="mtt-config-item-quantity">
              {{localize "mtt.settings.itemQuantityPath.name"}}
            </label>
            <i
              class="fas fa-circle-info mtt-config-info-icon"
              data-tooltip="{{localize 'mtt.settings.itemQuantityPath.hint'}}"
            ></i>
          </div>
          <input
            id="mtt-config-item-quantity"
            type="text"
            name="itemQuantityPath"
            value="{{itemQuantityPath}}"
            placeholder="system.quantity"
          />
        </div>

        <div class="mtt-config-field">
          <div class="mtt-config-field-header">
            <label class="mtt-config-field-label" for="mtt-config-item-delivery-quantity-per-lot">
              {{localize "mtt.settings.itemDeliveryQuantityPerLotPath.name"}}
            </label>
            <i
              class="fas fa-circle-info mtt-config-info-icon"
              data-tooltip="{{localize 'mtt.settings.itemDeliveryQuantityPerLotPath.hint'}}"
            ></i>
          </div>
          <input
            id="mtt-config-item-delivery-quantity-per-lot"
            type="text"
            name="itemDeliveryQuantityPerLotPath"
            value="{{itemDeliveryQuantityPerLotPath}}"
            placeholder="system.quantity.perLot"
          />
        </div>

        <div class="mtt-config-field">
          <div class="mtt-config-field-header">
            <label class="mtt-config-field-label" for="mtt-config-item-description">
              {{localize "mtt.settings.itemDescriptionPath.name"}}
            </label>
            <i
              class="fas fa-circle-info mtt-config-info-icon"
              data-tooltip="{{localize 'mtt.settings.itemDescriptionPath.hint'}}"
            ></i>
          </div>
          <input
            id="mtt-config-item-description"
            type="text"
            name="itemDescriptionPath"
            value="{{itemDescriptionPath}}"
            placeholder="system.description.value"
          />
        </div>

        <div class="mtt-config-field">
          <div class="mtt-config-field-header">
            <label class="mtt-config-field-label" for="mtt-config-item-secret-description">
              {{localize "mtt.settings.itemSecretDescriptionPath.name"}}
            </label>
            <i
              class="fas fa-circle-info mtt-config-info-icon"
              data-tooltip="{{localize 'mtt.settings.itemSecretDescriptionPath.hint'}}"
              aria-hidden="true"
            ></i>
          </div>
          <input
            id="mtt-config-item-secret-description"
            type="text"
            name="itemSecretDescriptionPath"
            value="{{itemSecretDescriptionPath}}"
            placeholder="system.description.unidentified"
          />
        </div>
      </div>
    </section>

    <section class="mtt-config-section">
      <h2 class="mtt-config-section-title">{{localize "mtt.config.sections.delivery"}}</h2>

      <div class="mtt-config-grid">
        <div class="mtt-config-field">
          <div class="mtt-config-field-header">
            <label class="mtt-config-field-label" for="mtt-config-delivery-quantity">
              {{localize "mtt.settings.deliveryItemQuantityPath.name"}}
            </label>
            <i
              class="fas fa-circle-info mtt-config-info-icon"
              data-tooltip="{{localize 'mtt.settings.deliveryItemQuantityPath.hint'}}"
            ></i>
          </div>
          <input
            id="mtt-config-delivery-quantity"
            type="text"
            name="deliveryItemQuantityPath"
            value="{{deliveryItemQuantityPath}}"
            placeholder="system.quantity.value"
          />
        </div>

        <div class="mtt-config-field">
          <div class="mtt-config-field-header">
            <label class="mtt-config-field-label" for="mtt-config-delivery-max-quantity">
              {{localize "mtt.settings.deliveryItemMaxQuantityPath.name"}}
            </label>
            <i
              class="fas fa-circle-info mtt-config-info-icon"
              data-tooltip="{{localize 'mtt.settings.deliveryItemMaxQuantityPath.hint'}}"
            ></i>
          </div>
          <input
            id="mtt-config-delivery-max-quantity"
            type="text"
            name="deliveryItemMaxQuantityPath"
            value="{{deliveryItemMaxQuantityPath}}"
            placeholder="system.quantity.max"
          />
        </div>

        <label class="mtt-config-checkbox-field">
          <input
            type="checkbox"
            name="writeDeliveryDescriptionInfo"
            {{#if writeDeliveryDescriptionInfo}}checked{{/if}}
          />
          <span>{{localize "mtt.settings.writeDeliveryDescriptionInfo.name"}}</span>
          <i
            class="fas fa-circle-info mtt-config-info-icon"
            data-tooltip="{{localize 'mtt.settings.writeDeliveryDescriptionInfo.hint'}}"
          ></i>
        </label>
      </div>
    </section>

    <section class="mtt-config-section">
      <h2 class="mtt-config-section-title">{{localize "mtt.config.sections.types"}}</h2>

      <div class="mtt-config-grid">
        <div class="mtt-config-field">
          <div class="mtt-config-field-header">
            <label class="mtt-config-field-label" for="mtt-config-product-types">
              {{localize "mtt.settings.allowedProductTypes.name"}}
            </label>
            <i
              class="fas fa-circle-info mtt-config-info-icon"
              data-tooltip="{{localize 'mtt.settings.allowedProductTypes.hint'}}"
            ></i>
          </div>
          <input id="mtt-config-product-types" type="text" name="allowedProductTypes" value="{{allowedProductTypes}}" />
        </div>

        <div class="mtt-config-field">
          <div class="mtt-config-field-header">
            <label class="mtt-config-field-label" for="mtt-config-service-types">
              {{localize "mtt.settings.allowedServiceTypes.name"}}
            </label>
            <i
              class="fas fa-circle-info mtt-config-info-icon"
              data-tooltip="{{localize 'mtt.settings.allowedServiceTypes.hint'}}"
            ></i>
          </div>
          <input id="mtt-config-service-types" type="text" name="allowedServiceTypes" value="{{allowedServiceTypes}}" />
        </div>
      </div>
    </section>

    <section class="mtt-config-section">
      <h2 class="mtt-config-section-title">{{localize "mtt.config.categories.title"}}</h2>

      <div class="mtt-config-field">
        <div class="mtt-config-field-header">
          <label class="mtt-config-field-label" for="mtt-config-category-paths">
            {{localize "mtt.settings.itemCategoryPaths.name"}}
          </label>
          <i
            class="fas fa-circle-info mtt-config-info-icon"
            data-tooltip="{{localize 'mtt.settings.itemCategoryPaths.hint'}}"
          ></i>
        </div>
        <textarea
          id="mtt-config-category-paths"
          name="itemCategoryPaths"
          class="mtt-config-textarea"
          placeholder="{{localize 'mtt.configuration.categoryPathsPlaceholder'}}"
        >{{itemCategoryPaths}}</textarea>
      </div>

      <div class="mtt-config-field">
        <div class="mtt-config-field-header">
          <label class="mtt-config-field-label" for="mtt-item-category-i18n-prefix">
            {{localize "mtt.config.categories.itemCategoryI18nPrefix.label"}}
          </label>
          <i
            class="fas fa-circle-info mtt-config-info-icon"
            data-tooltip="{{localize 'mtt.config.categories.itemCategoryI18nPrefix.hint'}}"
            aria-hidden="true"
          ></i>
        </div>
        <input
          id="mtt-item-category-i18n-prefix"
          type="text"
          name="itemCategoryI18nPrefix"
          value="{{itemCategoryI18nPrefix}}"
          placeholder="CO.equipment.subtypes."
        />
      </div>

      <div class="mtt-config-field">
        <div class="mtt-config-field-header">
          <label class="mtt-config-field-label" for="mtt-item-subcategory-path">
            {{localize "mtt.config.categories.itemSubcategoryPath.label"}}
          </label>
          <i
            class="fas fa-circle-info mtt-config-info-icon"
            data-tooltip="{{localize 'mtt.config.categories.itemSubcategoryPath.hint'}}"
            aria-hidden="true"
          ></i>
        </div>
        <input
          id="mtt-item-subcategory-path"
          type="text"
          name="itemSubcategoryPath"
          value="{{itemSubcategoryPath}}"
          placeholder="system.subtype"
        />
      </div>

      <div class="mtt-config-field">
        <div class="mtt-config-field-header">
          <label class="mtt-config-field-label" for="mtt-item-subcategory-i18n-prefix">
            {{localize "mtt.config.categories.itemSubcategoryI18nPrefix.label"}}
          </label>
          <i
            class="fas fa-circle-info mtt-config-info-icon"
            data-tooltip="{{localize 'mtt.config.categories.itemSubcategoryI18nPrefix.hint'}}"
            aria-hidden="true"
          ></i>
        </div>
        <input
          id="mtt-item-subcategory-i18n-prefix"
          type="text"
          name="itemSubcategoryI18nPrefix"
          value="{{itemSubcategoryI18nPrefix}}"
          placeholder="DND5E.Item.Type."
        />
      </div>

      <label class="mtt-config-checkbox-field">
        <input
          type="checkbox"
          name="useItemTypeAsCategoryFallback"
          {{#if useItemTypeAsCategoryFallback}}checked{{/if}}
        />
        <span>{{localize "mtt.settings.useItemTypeAsCategoryFallback.name"}}</span>
        <i
          class="fas fa-circle-info mtt-config-info-icon"
          data-tooltip="{{localize 'mtt.settings.useItemTypeAsCategoryFallback.hint'}}"
        ></i>
      </label>

      <div class="mtt-config-grid">
      <div class="mtt-config-field">
        <div class="mtt-config-field-header">
          <label class="mtt-config-field-label" for="mtt-config-category-map">
            {{localize "mtt.settings.categoryLabelMap.name"}}
          </label>
          <i
            class="fas fa-circle-info mtt-config-info-icon"
            data-tooltip="{{localize 'mtt.settings.categoryLabelMap.hint'}}"
          ></i>
        </div>
        <textarea
          id="mtt-config-category-map"
          name="categoryLabelMap"
          class="mtt-config-textarea"
          placeholder="{{localize 'mtt.configuration.categoryLabelMapPlaceholder'}}"
        >{{categoryLabelMap}}</textarea>
      </div>

      <div class="mtt-config-field">
        <div class="mtt-config-field-header">
          <label class="mtt-config-field-label" for="mtt-default-custom-categories">
            {{localize "mtt.config.categories.defaultCustomCategories.label"}}
          </label>
          <i
            class="fas fa-circle-info mtt-config-info-icon"
            data-tooltip="{{localize 'mtt.config.categories.defaultCustomCategories.hint'}}"
            aria-hidden="true"
          ></i>
        </div>
        <textarea
          id="mtt-default-custom-categories"
          name="defaultCustomCategories"
          class="mtt-config-textarea"
          rows="5"
        >{{defaultCustomCategories}}</textarea>
      </div>

      <div class="mtt-config-field">
        <div class="mtt-config-field-header">
          <label class="mtt-config-field-label" for="mtt-default-storage-categories">
            {{localize "mtt.config.categories.defaultStorageCategories.label"}}
          </label>
          <i
            class="fas fa-circle-info mtt-config-info-icon"
            data-tooltip="{{localize 'mtt.config.categories.defaultStorageCategories.hint'}}"
            aria-hidden="true"
          ></i>
        </div>
        <textarea
          id="mtt-default-storage-categories"
          name="defaultStorageCategories"
          class="mtt-config-textarea"
          rows="5"
        >{{defaultStorageCategories}}</textarea>
      </div>
      </div>
    </section>

    <section class="mtt-config-section mtt-config-currencies">
      <h2 class="mtt-config-section-title">{{localize "mtt.config.sections.currencies"}}</h2>
      <p class="mtt-config-explanation">{{localize "mtt.config.currencies.explanation"}}</p>

      <div class="mtt-config-currency-table">
        <div class="mtt-config-currency-table-head">
          <span>{{localize "mtt.config.currencies.columns.name"}}</span>
          <span>{{localize "mtt.config.currencies.columns.abbreviation"}}</span>
          <span
            data-tooltip="{{localize 'mtt.config.currencies.columns.actorPathHint'}}"
          >{{localize "mtt.config.currencies.columns.actorPath"}}</span>
          <span
            data-tooltip="{{localize 'mtt.config.currencies.columns.itemPricePathHint'}}"
          >{{localize "mtt.config.currencies.columns.itemPricePath"}}</span>
          <span
            data-tooltip="{{localize 'mtt.config.currencies.columns.itemCurrencyPathHint'}}"
          >{{localize "mtt.config.currencies.columns.itemCurrencyPath"}}</span>
          <span
            data-tooltip="{{localize 'mtt.config.currencies.columns.itemCurrencyValuesHint'}}"
          >{{localize "mtt.config.currencies.columns.itemCurrencyValues"}}</span>
          <span>{{localize "mtt.config.currencies.columns.rate"}}</span>
          <span>{{localize "mtt.config.currencies.columns.actions"}}</span>
        </div>

        <div class="mtt-config-currency-table-body">
          {{#each currencies as |currency|}}
            <div class="mtt-config-currency-row" data-currency-id="{{currency.id}}">
              <input
                type="text"
                class="mtt-config-currency-input"
                data-mtt-currency-field="name"
                value="{{currency.name}}"
                placeholder="{{localize 'mtt.config.currencies.namePlaceholder'}}"
              />
              <input
                type="text"
                class="mtt-config-currency-input"
                data-mtt-currency-field="abbreviation"
                value="{{currency.abbreviation}}"
                placeholder="{{localize 'mtt.config.currencies.abbrPlaceholder'}}"
              />
              <input
                type="text"
                class="mtt-config-currency-input"
                data-mtt-currency-field="actorPath"
                value="{{currency.actorPath}}"
                placeholder="{{localize 'mtt.config.currencies.actorPathPlaceholder'}}"
              />
              <input
                type="text"
                class="mtt-config-currency-input"
                data-mtt-currency-field="itemPricePath"
                value="{{currency.itemPricePath}}"
                placeholder="{{localize 'mtt.config.currencies.itemPricePathPlaceholder'}}"
              />
              <input
                type="text"
                class="mtt-config-currency-input"
                data-mtt-currency-field="itemCurrencyPath"
                value="{{currency.itemCurrencyPath}}"
                placeholder="{{localize 'mtt.config.currencies.itemCurrencyPathPlaceholder'}}"
              />
              <input
                type="text"
                class="mtt-config-currency-input"
                data-mtt-currency-field="itemCurrencyValues"
                value="{{currency.itemCurrencyValues}}"
                placeholder="{{localize 'mtt.config.currencies.itemCurrencyValuesPlaceholder'}}"
              />
              <input
                type="number"
                class="mtt-config-currency-input"
                data-mtt-currency-field="rate"
                value="{{currency.rate}}"
                min="0.0001"
                step="0.0001"
                placeholder="{{localize 'mtt.config.currencies.ratePlaceholder'}}"
              />
              <button
                type="button"
                class="mtt-config-currency-delete"
                data-action="deleteCurrency"
                data-currency-id="{{currency.id}}"
                data-tooltip="{{localize 'mtt.config.currencies.delete'}}"
              >
                <i class="fas fa-trash"></i>
              </button>
            </div>
          {{else}}
            <p class="mtt-config-currencies-empty">{{localize "mtt.config.currencies.empty"}}</p>
          {{/each}}
        </div>
      </div>

      <div class="mtt-config-currency-actions">
        <button
          type="button"
          class="mtt-config-btn mtt-config-btn--add"
          data-action="addCurrency"
          data-tooltip="{{localize 'mtt.config.currencies.add'}}"
        >
          <i class="fas fa-plus"></i>
          {{localize "mtt.config.currencies.add"}}
        </button>
      </div>
    </section>

    <footer class="mtt-config-footer">
      <button
        type="button"
        class="mtt-config-btn mtt-config-btn--save"
        data-action="save"
        data-tooltip="{{localize 'mtt.config.save'}}"
      >
        <i class="fas fa-floppy-disk"></i>
        {{localize "mtt.config.save"}}
      </button>
      <button
        type="button"
        class="mtt-config-btn mtt-config-btn--cancel"
        data-action="cancel"
        data-tooltip="{{localize 'mtt.config.cancel'}}"
      >
        <i class="fas fa-xmark"></i>
        {{localize "mtt.config.cancel"}}
      </button>
    </footer>
  </form>
</section>
