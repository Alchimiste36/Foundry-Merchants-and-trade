<form class="mtt-secret-info-dialog">
  <label class="mtt-secret-info-field">
    <span>{{localize "mtt.secrets.name"}}</span>
    <input type="text" name="secretName" value="{{secretName}}" />
  </label>

  <div class="mtt-secret-info-field">
    <span>{{localize "mtt.secrets.price"}}</span>
    <div class="mtt-secret-info-price-row">
      <input type="text" name="secretPrice" value="{{secretPrice}}" />
      <select name="secretCurrency" aria-label="{{localize 'mtt.secrets.currency'}}">
        {{#each currencyOptions as |currency|}}
          <option
            value="{{currency.key}}"
            {{#if currency.title}}title="{{currency.title}}"{{/if}}
            {{#if currency.selected}}selected{{/if}}
          >{{currency.abbreviation}}</option>
        {{/each}}
      </select>
    </div>
  </div>

  <label class="mtt-secret-info-field">
    <span>{{localize "mtt.secrets.description"}}</span>
    <textarea name="secretDescription">{{secretDescription}}</textarea>
  </label>
</form>
