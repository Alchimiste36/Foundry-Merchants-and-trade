<section class="mtt-dialog-preview-section">
  <h4 class="mtt-dialog-preview-section-title">
    {{#if isStorage}}
      {{localize "mtt.dialog.storage.moneyTransfer"}}
    {{else}}
      {{localize "mtt.dialog.transaction.moneyTransfer"}}
    {{/if}}
  </h4>
  {{#if moneyTransferGroups.length}}
    <div class="mtt-dialog-preview-money">
      {{#each moneyTransferGroups as |group|}}
        <p class="mtt-dialog-preview-money-line{{#if group.hasWarning}} mtt-dialog-preview-money-warning{{/if}}">
          <i class="fas fa-coins"></i>
          <span>{{group.sentence}}</span>
          {{#if group.hasWarning}}
            <i class="fas fa-triangle-exclamation mtt-dialog-preview-warning-icon"></i>
          {{/if}}
        </p>
      {{/each}}
    </div>
  {{else}}
    <p class="mtt-dialog-preview-empty">{{localize "mtt.dialog.transaction.noMoneyTransfer"}}</p>
  {{/if}}
</section>

{{#if warnings.length}}
  <ul class="mtt-dialog-preview-list mtt-dialog-preview-warnings">
    {{#each warnings as |warning|}}
      <li class="mtt-dialog-preview-warning">
        <i class="fas fa-triangle-exclamation"></i>
        {{warning}}
      </li>
    {{/each}}
  </ul>
{{/if}}

{{#if isPreviewOnly}}
  <p class="mtt-dialog-preview-notice">
    <i class="fas fa-circle-info"></i>
    {{localize "mtt.dialog.transaction.previewOnly"}}
  </p>
{{/if}}
