<div class="mtt-dialog-preview-header">
  <p><strong>{{localize "mtt.sessions.preview.client"}}</strong> {{clientName}}</p>
  <p><strong>{{localize "mtt.sessions.preview.merchant"}}</strong> {{merchantName}}</p>
</div>

<section class="mtt-dialog-preview-section">
  <h4 class="mtt-dialog-preview-section-title">
    {{#if isStorage}}
      {{localize "mtt.dialog.storage.actorReceives"}}
    {{else}}
      {{localize "mtt.dialog.transaction.buyerReceives"}}
    {{/if}}
  </h4>
  {{#if buyerReceives.length}}
    <div class="mtt-dialog-preview-table-wrap">
      <table class="mtt-dialog-preview-table">
        <thead>
          <tr>
            <th class="mtt-dialog-preview-col-img">{{localize "mtt.dialog.transaction.columns.image"}}</th>
            <th>{{localize "mtt.dialog.transaction.columns.type"}}</th>
            <th>{{localize "mtt.dialog.transaction.columns.quantity"}}</th>
            <th>{{localize "mtt.dialog.transaction.columns.name"}}</th>
            {{#unless isStorage}}
              <th>{{localize "mtt.dialog.transaction.columns.unitPrice"}}</th>
              <th>{{localize "mtt.dialog.transaction.columns.total"}}</th>
            {{/unless}}
          </tr>
        </thead>
        <tbody>
          {{#each buyerReceives as |item|}}
            <tr class="{{#if item.missing}}mtt-dialog-preview-row-missing{{/if}}">
              <td class="mtt-dialog-preview-col-img">
                {{#if item.img}}<img class="mtt-dialog-preview-img" src="{{item.img}}" alt="{{item.name}}" />{{/if}}
              </td>
              <td>{{item.typeLabel}}</td>
              <td class="mtt-dialog-preview-number">{{item.quantity}}</td>
              <td class="mtt-dialog-preview-name">{{item.name}}</td>
              {{#unless @root.isStorage}}
                <td class="mtt-dialog-preview-price">{{item.unitPriceLabel}}</td>
                <td class="mtt-dialog-preview-price">{{item.totalPriceLabel}}</td>
              {{/unless}}
            </tr>
          {{/each}}
        </tbody>
      </table>
    </div>
  {{else}}
    <p class="mtt-dialog-preview-empty">{{localize "mtt.dialog.transaction.empty"}}</p>
  {{/if}}
</section>

